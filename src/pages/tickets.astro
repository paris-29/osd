  <div class="mt-5 py-16 px-4 bg-gradient-to-r from-green-50 to-green-100">
    <div class="max-w-5xl mx-auto text-center">
      <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold text-black mb-10">
        Countdown to the Event 🚀
      </h3>

      <CountdownTimer client:load />
    </div>
  </div>

  <!-- Registration CTA -->
  <section class="py-15 mb-5 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-black mb-6">Ready to Register?</h2>
      <p class="text-xl text-black-300 mb-8">
        Secure your spot at OpenSource Weekend 2025. Limited seats available!
      </p>
      <a
