  <!-- Registration CTA -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-white mb-6">Ready to Register?</h2>
      <p class="text-xl text-black-300 mb-8">
        Secure your spot at OpenSource Weekend 2025. Limited seats available!
      </p>
      <a
        href="https://konfhub.com/open-source-day-2025"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-green-500 hover:bg-green-400 text-black px-12 py-4 rounded-full font-bold text-xl transition-all duration-200 glow-effect hover:scale-105 transform"
