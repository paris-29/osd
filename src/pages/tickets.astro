---
import CountdownTimer from "@components/CountdownTimer.jsx";
import Layout from "../components/Layout.astro";
import Navigation from "../components/Navigation.jsx";
import { TICKETS } from "../config.ts";
import "../styles/global.css";
---

<Layout title="Tickets - OpenSource Weekend 2025">
  <Navigation client:load />

  <!-- Page Header -->
  <section class="pt-12 pb-8 px-4 bg-white">
    <div class="max-w-6xl mx-auto text-center">
      <div class="mb-4 flex justify-center">
        <img src="/icons/OSDLogo.svg" alt="Open Source Day Logo" class="w-12 h-12 md:w-16 md:h-16" />
      </div>
      <h1 class="text-4xl md:text-6xl font-bold gradient-text mb-4">Get Your Tickets</h1>
      <div class="w-32 h-1 mx-auto mt-2 rounded-full bg-gradient-to-r from-green-300 to-green-500"></div>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto mt-4 mb-6">
        Choose the perfect ticket for your needs. All tickets include access to sessions, workshops, and networking opportunities.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          TICKETS.map((ticket) => (
            <div
              class={`relative light-card rounded-xl p-8 transition-all duration-300 hover:scale-102 ${
                ticket.popular
                  ? "border-green-500 ring-2 ring-green-500/20"
                  : "hover:border-green-500/40"
              }`}
            >
              {ticket.popular && (
                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                  <span class="bg-green-500 text-black px-4 py-2 rounded-full text-sm font-bold">
                    Most Popular
                  </span>
                </div>
              )}

              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-black mb-2">
                  {ticket.name}
                </h3>
                <p class="text-black mb-4">{ticket.description}</p>
                <div class="flex items-center justify-center space-x-2">
                  {ticket.originalPrice && (
                    <span class="text-2xl text-black-500 line-through">
                      {ticket.originalPrice}
                    </span>
                  )}
                  <span class="text-4xl font-bold gradient-text">
                    {ticket.price}
                  </span>
                </div>
              </div>

              <ul class="space-y-3 mb-8">
                {ticket.features.map((feature) => (
                  <li class="flex items-center space-x-3">
                    <svg
                      class="w-5 h-5 text-green-400 flex-shrink-0"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="text-black">{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href={ticket.konfhubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={`block w-full py-4 rounded-full font-bold text-lg transition-all duration-200 text-center ${
                  ticket.popular
                    ? "bg-green-500 hover:bg-green-400 text-black glow-effect"
                    : "border-2 border-green-500 text-green-400 hover:bg-green-500 hover:text-black"
                }`}
              >
                {ticket.available ? "Register Now" : "Sold Out"}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

