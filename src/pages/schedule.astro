  {
    time: "5:30 PM",
    title: "Final Networking & Farewell",
    speaker: "",
    type: "social",
    room: "Exhibition Hall"
  }
];

const getTypeColor = (type: string) => {
  switch (type) {
    case 'keynote': return 'bg-green-500/20 border-green-500/40 text-green-400';
    case 'talk': return 'bg-blue-500/20 border-blue-500/40 text-blue-400';
    case 'workshop': return 'bg-purple-500/20 border-purple-500/40 text-purple-400';
    case 'panel': return 'bg-orange-500/20 border-orange-500/40 text-orange-400';
    case 'break': return 'bg-gray-500/20 border-gray-500/40 text-black-400';
    case 'social': return 'bg-pink-500/20 border-pink-500/40 text-pink-400';
    default: return 'bg-gray-500/20 border-gray-500/40 text-black-400';
  }
};
---

<Layout title="Schedule - OpenSource Weekend 2025">
  <Navigation client:load />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-bold gradient-text mb-6">Event Schedule</h1>
      <p class="text-xl text-black max-w-3xl mx-auto mb-8">
        A full day packed with inspiring talks, hands-on workshops, networking opportunities, 
        and celebrating open source innovation.
      </p>
      <div class="flex justify-center">
        <div class="bg-green-500 text-white px-8 py-3 rounded-full font-semibold">
          February 15, 2025
        </div>
      </div>
    </div>
  </section>

  <!-- Legend -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="light-card rounded-xl p-6">
        <h3 class="text-xl font-bold text-black mb-4">Session Types</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-green-500/20 border border-green-500/40"></div>
            <span class="text-sm text-black">Keynote</span>
          </div>
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-blue-500/20 border border-blue-500/40"></div>
            <span class="text-sm text-black">Talk</span>
          </div>
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-purple-500/20 border border-purple-500/40"></div>
            <span class="text-sm text-black">Workshop</span>
          </div>
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-orange-500/20 border border-orange-500/40"></div>
            <span class="text-sm text-black">Panel</span>
          </div>
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-gray-500/20 border border-gray-500/40"></div>
            <span class="text-sm text-black">Break</span>
          </div>
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-pink-500/20 border border-pink-500/40"></div>
            <span class="text-sm text-black">Social</span>
          </div>
          <div class="flex items-center space-x-2">
            <div class="w-4 h-4 rounded bg-yellow-500/20 border border-yellow-500/40"></div>
            <span class="text-sm text-black">Awards</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Day 1 Schedule -->
  <!-- <section id="day1" class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
