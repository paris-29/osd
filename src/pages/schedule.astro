              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section> -->

  <!-- Day 2 Schedule -->
  <section id="day2" class="py-20 px-4 bg-gradient-to-r from-green-50 to-green-100">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-center text-black mb-12">
        <span class="gradient-text">October 05, 2025</span>
      </h2>
      <div class="space-y-4">
        {day2Schedule.map((session) => (
          <div class="light-card rounded-xl p-6 transition-all duration-300">
            <div class="flex flex-col md:flex-row md:items-center justify-between">
              <div class="flex-1">
                <div class="flex items-center space-x-4 mb-2">
                  <span class="text-green-600 font-bold text-lg min-w-[80px]">{session.time}</span>
                  <span class={`px-3 py-1 rounded-full text-xs font-semibold border ${getTypeColor(session.type)}`}>
                    {session.type.charAt(0).toUpperCase() + session.type.slice(1)}
                  </span>
                </div>
                <h3 class="text-xl font-bold text-black mb-1">{session.title}</h3>
                {session.speaker && (
                  <p class="text-black mb-2">by {session.speaker}</p>
                )}
                <p class="text-sm text-gray-600">{session.room}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Download Schedule -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-black mb-6">Take It With You</h2>
      <p class="text-xl text-black mb-8">
        Download the complete schedule and add it to your calendar so you don't miss anything!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/schedule.pdf"
          class="bg-green-500 hover:bg-green-400 text-white px-8 py-4 rounded-full font-bold text-lg transition-all duration-200 glow-effect hover:scale-105 transform"
        >
          Download PDF
        </a>
        <a
          href="/schedule.ics"
          class="border-2 border-green-500 text-green-600 hover:bg-green-500 hover:text-white px-8 py-4 rounded-full font-bold text-lg transition-all duration-200 hover:scale-105 transform"
        >
          Add to Calendar
        </a>
      </div>
    </div>
  </section>
</Layout>