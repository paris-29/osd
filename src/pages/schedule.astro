---
import Layout from "@/layouts/Layout.astro";
import Heading from "@components/Heading.astro";
import AddToGoogleCalendar from "@components/AddToGoogleCalendar";
import "@/styles/global.css";

import { eventSchedule, workshopSchedule, fullEvent } from "@/config";

const getTypeColor = (type: string) => {
  const colorMap: Record<string, string> = {
    registration: "bg-gray-100",
    "community panel": "bg-green-300", // Note: this seems like a typo
    opening: "bg-gray-100",
    keynote: "bg-yellow-200",
    "closing keynote": "bg-yellow-200",
    talk: "bg-blue-200",
    "cxo panel": "bg-lime-300",
    break: "bg-gray-100",
    closing: "bg-gray-100",
    social: "bg-gray-100",
    activity: "bg-gray-100",
  };

  return colorMap[type.toLowerCase()] || "bg-pink-300";
};
---

<Layout title="Schedule — 2025 OSD" activePath="/schedule">
  <!-- Heading Section -->
  <Heading
    title="Event Schedule"
    description="A full day packed with inspiring talks, hands-on workshops, networking opportunities, and celebrating open source innovation."
  />

  <section class="w-full flex flex-col gap-5 justify-center">
    <!-- OSD Schedule -->
    <section
      id="day2"
      class="py-20 px-4 w-full bg-gradient-to-t to-green-50 from-green-300"
    >
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col flex-1 items-center">
          <h2 class="text-4xl font-bold text-center text-black mb-4">
            <span class="gradient-text">Open Source Day 2025</span>
            <span class="text-lg block text-green-500"
              >Silver Oak University (5th October 2025)</span
            >
          </h2>
          <div class="btn mb-12 w-fit">
            <AddToGoogleCalendar event={fullEvent} client:load />
          </div>
        </div>

        <div class="space-y-4">
          {
            eventSchedule.map((session) => (
              <div class="light-card rounded-xl p-6 transition-all duration-300">
                <div class="flex flex-col gap-5 md:flex-row md:items-center justify-between">
                  <div class="flex-1">
                    <div class="flex items-center space-x-4 mb-2">
                      <span class="text-green-600 font-bold text-lg min-w-[80px]">
                        {session.time}
                      </span>
                      <span
                        class={`px-3 py-1 whitespace-nowrap rounded-full text-xs font-semibold border-2  text-black border-black ${getTypeColor(
                          session.type
                        )}`}
                      >
                        {session.type.toUpperCase()}
                      </span>
                    </div>
                    <h3 class="text-xl font-bold text-black mb-1">
                      {session.title}
                    </h3>
                    {session.speaker && (
                      <p class="text-black mb-2">by {session.speaker}</p>
                    )}
                    <p class="text-sm text-gray-600">{session.room}</p>
                  </div>
                  <div class="btn">
                    <AddToGoogleCalendar event={session} client:load />
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </section>

  <!-- Download Schedule -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-black mb-6">Take It With You</h2>
      <p class="text-xl text-black mb-8">
        Download the complete schedule and add it to your calendar so you don't
        miss anything!
      </p>
    </div>
  </section>

  <!-- Workshop Schedule -->
  <section id="workshop" class="py-20 px-4 bg-white w-full">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-center text-black mb-12">
        <span class="gradient-text">Open Source with AI</span>
        <span class="text-lg block text-green-500"
          >Workshop at Aubergine (27th September 2025)</span
        >
      </h2>
      <div class="space-y-4">
        {
          workshopSchedule.map((session) => (
            <div class="light-card rounded-xl p-6 transition-all duration-300">
              <div class="flex flex-col gap-5 md:flex-row md:items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center space-x-4 mb-2">
                    <span class="text-green-600 font-bold text-lg min-w-[80px]">
                      {session.time}
                    </span>
                    <span
                      class={`px-3 py-1 rounded-full text-xs font-semibold border ${getTypeColor(session.type)}`}
                    >
                      {session.type.charAt(0).toUpperCase() +
                        session.type.slice(1)}
                    </span>
                  </div>
                  <h3 class="text-xl font-bold text-black mb-1">
                    {session.title}
                  </h3>
                  {session.speaker && (
                    <p class="text-black mb-2">by {session.speaker}</p>
                  )}
                  <p class="text-sm text-gray-600">{session.room}</p>
                </div>
                <div class="btn">
                  <AddToGoogleCalendar event={session} client:load />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
