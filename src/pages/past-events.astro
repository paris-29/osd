---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
import PageHero from "@/components/PageHero.jsx";
import { PastEvent } from "@/config/config.ts";

// OSD 2025 photos — use first event group (May 2025 or latest)
const osd2025Photos = PastEvent[0]?.images?.slice(0, 4) ?? [];
---

<Layout title="Past Events — Open Source Day" activePath="/past-events">
  <!-- Hero -->
  <PageHero
    client:load
    badge="5 YEARS OF OPEN SOURCE DAY"
    title="OUR"
    titleGradient="PAST EVENTS"
    subtitle="From humble beginnings to India's largest open source conference — look back at the journey."
    primaryCta={{ text: "Explore OSD 2025", href: "/2025/" }}
  />

  <!-- OSD 2025 Highlight -->
  <section id="osd-2025" class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center gap-4 mb-10">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent to-green-200"></div>
        <span class="text-xs font-bold text-green-700 uppercase tracking-widest px-4 py-1.5 rounded-full border border-green-200 bg-green-50 whitespace-nowrap"
          >Most Recent</span
        >
        <div class="h-px flex-1 bg-gradient-to-l from-transparent to-green-200"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="inline-block px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-bold mb-4 border border-green-100">OCT 2025</span>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-4">Open Source Day <span class="gradient-text">2025</span></h2>
          <p class="text-gray-500 mb-6 leading-relaxed">
            OSD 2025 was held at Silver Oak University, Ahmedabad — our biggest edition yet. 600+ attendees, 20+ talks, sold-out workshops, and an incredible
            open source community.
          </p>
          <div class="grid grid-cols-3 gap-4 mb-8">
            {
              [
                ["600+", "Attendees"],
                ["20+", "Sessions"],
                ["70+", "Partners"],
              ].map(([num, label]) => (
                <div class="border border-gray-100 rounded-2xl p-4 text-center hover:border-green-100 transition-colors">
                  <div class="text-2xl font-black gradient-text">{num}</div>
                  <div class="text-gray-500 text-xs mt-1">{label}</div>
                </div>
              ))
            }
          </div>
          <a
            href="/2025/"
            class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-6 py-3 rounded-full transition-all hover:scale-105"
          >
            Visit OSD 2025 Site
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-2 gap-3">
          {
            osd2025Photos.length > 0
              ? osd2025Photos.map((img: any) => (
                  <div class="rounded-2xl overflow-hidden aspect-square bg-gray-50 border border-gray-100">
                    <img src={img.src} alt="OSD 2025" loading="lazy" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
                  </div>
                ))
              : [1, 2, 3, 4].map((i) => (
                  <div class="bg-gray-50 border border-gray-100 rounded-2xl aspect-square flex items-center justify-center text-gray-300 text-xs">
                    Photo {i}
                  </div>
                ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- The Journey — Accordion -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">The <span class="gradient-text">Journey</span></h2>
        <p class="text-gray-500">Open Source Day has been growing every year — click each year to explore</p>
      </div>

      <div class="space-y-3" id="journey-accordion">
        <!-- 2026 upcoming -->
        <div class="border border-green-200 bg-white rounded-2xl overflow-hidden">
          <div class="flex items-center gap-4 p-5">
            <div class="text-3xl font-black gradient-text shrink-0">2026</div>
            <div class="flex-1">
              <div class="font-bold text-gray-900">Open Source Day 2026</div>
              <div class="text-gray-500 text-sm">TBA · Ahmedabad, Gujarat</div>
            </div>
            <span class="text-xs font-bold text-green-700 bg-green-50 border border-green-100 px-3 py-1 rounded-full shrink-0">Upcoming</span>
          </div>
        </div>

        <!-- 2025 OSD -->
        <div class="border border-gray-100 bg-white rounded-2xl overflow-hidden accordion-item">
          <button class="accordion-trigger w-full flex items-center gap-4 p-5 text-left hover:bg-gray-50 transition-colors">
            <div class="text-3xl font-black text-gray-300 shrink-0">2025</div>
            <div class="flex-1">
              <div class="font-bold text-gray-900">Open Source Day 2025</div>
              <div class="text-gray-500 text-sm">Silver Oak University · 600+ attendees · 20+ sessions</div>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <a href="#osd-2025" class="text-sm font-semibold text-green-600 hover:underline" onclick="event.stopPropagation()">View →</a>
              <svg class="accordion-chevron w-5 h-5 text-gray-400 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg
              >
            </div>
          </button>
          <div class="accordion-panel hidden px-5 pb-5">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {
                PastEvent.filter((e) => e.year === "2025")
                  .flatMap((e) => e.images)
                  .slice(0, 8)
                  .map((img: any) => (
                    <div class="rounded-xl overflow-hidden aspect-square bg-gray-100">
                      <img src={img.src} alt="OSD 2025" loading="lazy" class="w-full h-full object-cover" />
                    </div>
                  ))
              }
            </div>
          </div>
        </div>

        <!-- 2024 -->
        <div class="border border-gray-100 bg-white rounded-2xl overflow-hidden accordion-item">
          <button class="accordion-trigger w-full flex items-center gap-4 p-5 text-left hover:bg-gray-50 transition-colors">
            <div class="text-3xl font-black text-gray-300 shrink-0">2024</div>
            <div class="flex-1">
              <div class="font-bold text-gray-900">Open Source Day 2024</div>
              <div class="text-gray-500 text-sm">Another milestone year for the open source community</div>
            </div>
            <svg
              class="accordion-chevron w-5 h-5 text-gray-400 transition-transform duration-300 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg
            >
          </button>
          <div class="accordion-panel hidden px-5 pb-5">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {
                PastEvent.filter((e) => e.year === "2024")
                  .flatMap((e) => e.images)
                  .slice(0, 8)
                  .map((img: any) => (
                    <div class="rounded-xl overflow-hidden aspect-square bg-gray-100">
                      <img src={img.src} alt="OSD 2024" loading="lazy" class="w-full h-full object-cover" />
                    </div>
                  ))
              }
            </div>
          </div>
        </div>

        <!-- 2023 -->
        <div class="border border-gray-100 bg-white rounded-2xl overflow-hidden accordion-item">
          <button class="accordion-trigger w-full flex items-center gap-4 p-5 text-left hover:bg-gray-50 transition-colors">
            <div class="text-3xl font-black text-gray-300 shrink-0">2023</div>
            <div class="flex-1">
              <div class="font-bold text-gray-900">Open Source Day 2023</div>
              <div class="text-gray-500 text-sm">Growing the community across Gujarat and beyond</div>
            </div>
            <svg
              class="accordion-chevron w-5 h-5 text-gray-400 transition-transform duration-300 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg
            >
          </button>
          <div class="accordion-panel hidden px-5 pb-5">
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {
                PastEvent.filter((e) => e.year === "2023")
                  .flatMap((e) => e.images)
                  .slice(0, 8)
                  .map((img: any) => (
                    <div class="rounded-xl overflow-hidden aspect-square bg-gray-100">
                      <img src={img.src} alt="OSD 2023" loading="lazy" class="w-full h-full object-cover" />
                    </div>
                  ))
              }
            </div>
          </div>
        </div>

        <!-- 2022 -->
        <div class="border border-gray-100 bg-white rounded-2xl overflow-hidden">
          <div class="flex items-center gap-4 p-5">
            <div class="text-3xl font-black text-gray-300 shrink-0">2022</div>
            <div class="flex-1">
              <div class="font-bold text-gray-900">Open Source Day 2022</div>
              <div class="text-gray-500 text-sm">Back in person after the pandemic, stronger than ever</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Community CTA -->
  <section class="py-16 px-4 bg-white text-center">
    <h3 class="text-2xl font-black text-gray-900 mb-3">Be part of <span class="gradient-text">OSD 2026</span></h3>
    <p class="text-gray-500 mb-6 max-w-xl mx-auto">The next chapter is being written. Join the community to stay updated and get involved.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://chat.whatsapp.com/Fi50G9prGcH4b7891LrPir"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105"
      >
        Join WhatsApp Community
      </a>
      <a href="/" class="inline-flex items-center gap-2 font-semibold text-gray-500 hover:text-gray-900 transition-colors"> Get Involved → </a>
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll(".accordion-trigger").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const item = trigger.closest(".accordion-item");
      const panel = item?.querySelector(".accordion-panel");
      const chevron = trigger.querySelector(".accordion-chevron");
      const isOpen = !panel?.classList.contains("hidden");

      // Close all
      document.querySelectorAll(".accordion-panel").forEach((p) => p.classList.add("hidden"));
      document.querySelectorAll(".accordion-chevron").forEach((c) => c.classList.remove("rotate-180"));

      // Open clicked if it was closed
      if (!isOpen) {
        panel?.classList.remove("hidden");
        chevron?.classList.add("rotate-180");
      }
    });
  });
</script>
