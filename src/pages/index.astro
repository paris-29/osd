---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
import { CALLS_2026, VENUE, TICKETS } from "@/config/config.ts";
import Hero from "@/components/Hero.jsx";
import Counter from "@/components/Counter.jsx";
import ScrollAnimations from "@/components/ScrollAnimations.jsx";
import MarqueeLogos from "@/components/MarqueeLogos.jsx";
import LearnAndContribute from "@/assets/icons/learn-contribute.svg";
import Connect from "@/assets/icons/connect.svg";
import Celebrate from "@/assets/icons/celebrate.svg";
import LocationIcon from "@/assets/icons/location.svg";
import CalendarClock from "@/assets/icons/calendarClock.svg";

import { sponsorsData } from "@/lib/graphql/queries/sponsors.query.ts";
import { speakersData } from "@/lib/graphql/queries/speakers.query.ts";
import { env } from "@/lib/env.ts";

// ── helpers ──────────────────────────────────────────────────────────
function strapiImg(url: string | null | undefined): string | null {
  if (!url) return null;
  const t = url.trim();
  return t.startsWith("http") ? t : `${env.STRAPI_BASE_URL}${t}`;
}

// ── sponsors ─────────────────────────────────────────────────────────
const rawSponsorGroups = (sponsorsData as any)?.sponsors?.[0]?.sponsors ?? [];
const sponsorGroups = rawSponsorGroups.map((g: any) => ({
  ...g,
  sponsors: g.sponsors.map((s: any) => ({
    ...s,
    logoUrl: strapiImg(s.logo?.url),
    // shape MarqueeLogos expects: { logo, name }
    logo: strapiImg(s.logo?.url),
  })),
}));

// Threshold: if a group has more than this many sponsors → marquee; else → grid
const MARQUEE_THRESHOLD = 5;

// ── speakers ─────────────────────────────────────────────────────────
const allSpeakers = ((speakersData as any)?.speakers?.[0]?.ourSpeakers ?? [])
  .flatMap((sec: any) => sec.speakers ?? [])
  .map((s: any) => ({
    ...s,
    imageUrl: strapiImg(s.image?.url),
    linkedinUrl: s.link?.trim() || null,
  }));
---

<Layout title="Open Source Day 2026" activePath="/">
  <Hero client:load />
  <ScrollAnimations client:load />

  <!-- ─── GET INVOLVED ─── -->
  <section class="py-24 px-4 bg-white" id="get-involved">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-50 text-green-700 text-sm font-bold border border-green-100 mb-6 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Forms are LIVE
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">Get Involved in <span class="gradient-text">OSD 2026</span></h2>
        <p class="text-lg text-gray-500 max-w-2xl mx-auto">
          Whether you want to speak, volunteer, sponsor, or spread the word — there's a place for you at Open Source Day.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {CALLS_2026.map((call) => (
          <a
            href={call.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group border border-gray-100 bg-white hover:border-green-200 hover:shadow-lg p-7 rounded-2xl transition-all duration-300 flex flex-col"
          >
            <div class="w-11 h-11 bg-green-50 border border-green-100 rounded-xl mb-5 flex items-center justify-center text-xl group-hover:bg-green-500 group-hover:scale-110 transition-all duration-300">
              {call.emoji}
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{call.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed flex-1">{call.description}</p>
            <div class="mt-5 flex items-center text-sm font-semibold text-green-600 group-hover:text-green-700">
              Apply Now
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </a>
        ))}
      </div>

      <p class="text-center text-gray-400 text-sm mt-10">
        Questions? Reach us at
        <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-medium ml-1">opensourceweekend@gmail.com</a>
      </p>
    </div>
  </section>

  <!-- ─── ABOUT ─── -->
  <section class="py-24 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <div class="mb-6 flex justify-center">
          <img src="/icons/OSDGreen.svg" alt="Open Source Day Logo" class="w-14 h-14" loading="eager" />
        </div>
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">About <span class="gradient-text">Open Source Day</span></h2>
        <p class="text-lg text-gray-500 max-w-3xl mx-auto">
          Open Source Day 2026 is a community-driven conference celebrating the power of open source software. Join developers, maintainers, and builders for a full day of learning, collaboration, and innovation in Ahmedabad.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white border border-gray-100 p-8 rounded-2xl hover:shadow-md hover:border-green-100 transition-all duration-300">
          <div class="w-11 h-11 bg-green-500 rounded-xl mb-5 flex items-center justify-center text-white">
            <LearnAndContribute />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Learn & Contribute</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Discover new technologies, learn best practices, and get hands-on experience contributing to real open source projects.</p>
        </div>
        <div class="bg-white border border-gray-100 p-8 rounded-2xl hover:shadow-md hover:border-green-100 transition-all duration-300">
          <div class="w-11 h-11 bg-green-500 rounded-xl mb-5 flex items-center justify-center text-white">
            <Connect />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Connect</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Network with fellow developers, open source maintainers, and tech enthusiasts from across the Indian tech community.</p>
        </div>
        <div class="bg-white border border-gray-100 p-8 rounded-2xl hover:shadow-md hover:border-green-100 transition-all duration-300">
          <div class="w-11 h-11 bg-green-500 rounded-xl mb-5 flex items-center justify-center text-white">
            <Celebrate />
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Celebrate</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Celebrate open source achievements and discover exciting new projects, communities, and opportunities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── IMPACT STATS ─── -->
  <section class="py-24 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">Building <span class="gradient-text">Impact</span> in 2026</h2>
        <p class="text-lg text-gray-500">What we're aiming for — bigger and better than ever</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-gray-100 rounded-2xl overflow-hidden border border-gray-100">
        {[
          { value: 1000, suffix: "+", label: "Expected Attendees" },
          { value: 80, suffix: "+", label: "Community Partners" },
          { value: 30, suffix: "+", label: "Expert Speakers" },
          { value: 15, suffix: "+", label: "Technical Sessions" },
        ].map(({ value, suffix, label }) => (
          <div class="flex flex-col items-center py-10 px-6 bg-white">
            <div class="text-4xl md:text-5xl font-black gradient-text mb-2">
              <Counter target={value} client:visible />{suffix}
            </div>
            <div class="text-sm text-gray-500 font-medium text-center">{label}</div>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-3 gap-px bg-gray-100 rounded-2xl overflow-hidden border border-gray-100 mt-px">
        <div class="flex flex-col items-center py-10 px-6 bg-white">
          <div class="text-4xl md:text-5xl font-black gradient-text mb-2"><Counter target={3} client:visible />+</div>
          <div class="text-sm text-gray-500 font-medium text-center">Panel Discussions</div>
        </div>
        <div class="flex flex-col items-center py-10 px-6 bg-white">
          <div class="text-4xl md:text-5xl font-black gradient-text mb-2"><Counter target={6} client:visible />+</div>
          <div class="text-sm text-gray-500 font-medium text-center">Workshops</div>
        </div>
        <div class="flex flex-col items-center py-10 px-6 bg-white">
          <div class="text-4xl md:text-5xl font-black gradient-text mb-2">1</div>
          <div class="text-sm text-gray-500 font-medium text-center">Full Day Event</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SPONSORS & PARTNERS ─── -->
  <section class="py-24 px-4 bg-gray-50" id="sponsors">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">Sponsors &amp; <span class="gradient-text">Partners</span></h2>
        <p class="text-lg text-gray-500">Thank you to the organizations making OSD 2026 possible</p>
      </div>

      {sponsorGroups.length > 0 ? (
        <div class="space-y-12">
          {sponsorGroups.map((group: any) => (
            <div>
              <div class="flex items-center gap-4 mb-8">
                <div class="h-px flex-1 bg-gradient-to-r from-transparent to-green-200"></div>
                <span class="text-xs font-bold text-green-700 uppercase tracking-widest px-4 py-1.5 rounded-full border border-green-200 bg-green-50 whitespace-nowrap">
                  {group.title}
                </span>
                <div class="h-px flex-1 bg-gradient-to-l from-transparent to-green-200"></div>
              </div>

              {group.sponsors.length > MARQUEE_THRESHOLD ? (
                <div class="w-full">
                  <MarqueeLogos client:load logos={group.sponsors} duration={80} height={100} itemMinWidth={220} />
                </div>
              ) : (
                <div class={`grid gap-5 ${
                  group.sponsors.length === 1 ? "grid-cols-1 max-w-xs mx-auto"
                  : group.sponsors.length === 2 ? "grid-cols-1 sm:grid-cols-2 max-w-xl mx-auto"
                  : "grid-cols-1 sm:grid-cols-2 md:grid-cols-3"
                }`}>
                  {group.sponsors.map((sponsor: any) => (
                    <a
                      href={sponsor.website && sponsor.website !== "#" ? sponsor.website : undefined}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group relative bg-white border border-gray-100 rounded-2xl p-8 flex flex-col items-center justify-center gap-3 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-green-200"
                    >
                      <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-green-400 to-emerald-500 rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                      {sponsor.logoUrl ? (
                        <img src={sponsor.logoUrl} alt={`${sponsor.name} logo`} loading="lazy" class="max-h-16 w-auto object-contain transition-transform duration-300 group-hover:scale-105" />
                      ) : (
                        <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center">
                          <span class="text-green-700 font-black text-xl">{sponsor.name.charAt(0)}</span>
                        </div>
                      )}
                      <span class="text-xs font-semibold text-gray-500 group-hover:text-green-700 transition-colors text-center">{sponsor.name}</span>
                    </a>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-gray-400">
          <p class="text-lg font-medium">Sponsor announcements coming soon!</p>
          <p class="text-sm mt-1">Interested? <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline">Get in touch</a></p>
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/sponsors" class="inline-flex items-center gap-2 font-semibold text-gray-700 border-2 border-gray-900 px-6 py-3 rounded-full hover:bg-gray-900 hover:text-white transition-all duration-200">
          View All Sponsors &amp; Partners
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>


  <!-- ─── SPEAKERS PREVIEW ─── -->
  <section class="py-24 px-4 bg-white" id="speakers">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">Our <span class="gradient-text">Speakers</span></h2>
        <p class="text-lg text-gray-500">Our 2026 speaker lineup is coming together. Apply to share your expertise!</p>
      </div>

      {allSpeakers.length > 0 ? (
        allSpeakers.length > MARQUEE_THRESHOLD ? (
          <!-- Marquee for many speakers -->
          <div class="w-full mb-10">
            <MarqueeLogos
              client:load
              logos={allSpeakers.map((s: any) => ({ logo: s.imageUrl, name: s.name }))}
              duration={60}
              height={120}
              itemMinWidth={120}
            />
          </div>
        ) : (
          <!-- Grid for small number of speakers -->
          <div class={`grid gap-5 mb-10 ${
            allSpeakers.length === 1
              ? "grid-cols-1 max-w-xs mx-auto"
              : allSpeakers.length === 2
              ? "grid-cols-1 sm:grid-cols-2 max-w-xl mx-auto"
              : "grid-cols-1 sm:grid-cols-2 md:grid-cols-3"
          }`}>
            {allSpeakers.map((sp: any) => (
              <a
                href={sp.linkedinUrl || undefined}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative bg-white border border-gray-100 rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-green-200 flex flex-col"
              >
                <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-green-400 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity z-10"></div>

                <!-- Photo -->
                <div class="relative w-full aspect-[4/5] bg-gradient-to-br from-green-50 to-emerald-100 overflow-hidden">
                  {sp.imageUrl ? (
                    <img
                      src={sp.imageUrl}
                      alt={sp.name}
                      loading="lazy"
                      class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <span class="text-5xl font-black text-green-200">{sp.name.charAt(0)}</span>
                    </div>
                  )}

                  {sp.event && (
                    <div class="absolute top-3 left-3 z-20">
                      <span class="bg-gray-900/90 text-white text-[0.6rem] font-black uppercase tracking-widest px-2.5 py-1 rounded-full">
                        {sp.event.trim()}
                      </span>
                    </div>
                  )}

                  {sp.linkedinUrl && (
                    <div class="absolute bottom-0 left-0 right-0 z-20 flex items-center gap-2.5 px-4 py-3
                                bg-[#0A66C2] text-white
                                translate-y-full group-hover:translate-y-0
                                transition-transform duration-300 ease-out">
                      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                      <span class="text-xs font-bold">View on LinkedIn</span>
                    </div>
                  )}
                </div>

                <!-- Info -->
                <div class="p-4 border-t border-gray-100">
                  <h4 class="font-bold text-gray-900 text-sm leading-tight mb-0.5">{sp.name}</h4>
                  <div class="text-xs text-gray-500">{sp.position}{sp.position && sp.company ? " · " : ""}{sp.company?.trim()}</div>
                  {sp.event && (
                    <span class="inline-block mt-2 px-2.5 py-0.5 bg-green-50 text-green-700 rounded-full text-[0.6rem] font-bold uppercase tracking-wide border border-green-100">
                      {sp.event.trim()}
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        )
      ) : (
        <p class="text-center text-gray-400 mb-10">Speaker announcements coming soon — <a href="/cfspk" class="text-green-600 hover:underline font-medium">apply to speak!</a></p>
      )}

      <div class="text-center">
        <a href="/speakers" class="group inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-4 rounded-full transition-all duration-200 hover:scale-105">
          View All Speakers
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ─── VENUE + TICKETS ─── -->
  <section class="py-24 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Venue Card -->
      <div class="bg-white border border-gray-100 rounded-2xl p-8 flex flex-col hover:shadow-md hover:border-green-100 transition-all duration-300">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center text-green-600 border border-green-100">
            <LocationIcon />
          </div>
          <h3 class="text-xl font-black text-gray-900">Venue</h3>
        </div>
        <div class="text-2xl font-bold text-gray-800 mb-1">{VENUE.name}</div>
        <div class="text-gray-500 text-sm mb-6">{VENUE.address}</div>
        <div class="flex items-center gap-2 text-sm text-gray-400 mb-auto">
          <CalendarClock class="w-4 h-4" />
          TBA · Ahmedabad, Gujarat
        </div>
        <a href="/venue" class="mt-6 block text-center bg-gray-900 hover:bg-gray-800 text-white px-6 py-3 rounded-full font-bold text-sm transition-all hover:scale-105">
          Venue Details
        </a>
      </div>

      <!-- Tickets Card -->
      <div class="bg-white border border-gray-100 rounded-2xl p-8 flex flex-col hover:shadow-md hover:border-green-100 transition-all duration-300">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center text-green-600 border border-green-100">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a3 3 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" />
            </svg>
          </div>
          <h3 class="text-xl font-black text-gray-900">Tickets</h3>
        </div>

        <div class="flex flex-col gap-3 mb-auto">
          {TICKETS.slice(0, 2).map((t) => (
            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl border border-gray-100">
              <div>
                <div class="font-semibold text-gray-900 text-sm">{t.name}</div>
                <div class="text-xs text-gray-400 mt-0.5">{t.description?.slice(0, 55)}…</div>
              </div>
              <div class="font-bold text-green-700 text-sm shrink-0 ml-2">{t.price}</div>
            </div>
          ))}
        </div>
        <a href="/tickets" class="mt-6 block text-center bg-green-500 hover:bg-green-400 text-white px-6 py-3 rounded-full font-bold text-sm transition-all glow-effect hover:scale-105">
          View All Tickets
        </a>
      </div>
    </div>
  </section>

  <!-- ─── COMMUNITY CTA ─── -->
  <section class="py-24 px-4 bg-white">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-black text-gray-900 mb-4">Ready to <span class="gradient-text">Join Us?</span></h2>
      <p class="text-lg text-gray-500 mb-10">
        Don't miss out on India's biggest open source community event. Join our WhatsApp community to stay updated!
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://chat.whatsapp.com/Fi50G9prGcH4b7891LrPir" target="_blank" rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-4 rounded-full transition-all duration-200 hover:scale-105">
          Join WhatsApp Community
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="/2025/" class="inline-flex items-center gap-2 font-semibold text-gray-500 hover:text-gray-900 transition-colors">
          Explore OSD 2025
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
