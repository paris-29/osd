---
import Layout from "@/layouts/Layout.astro";
import { BRANDING, CALLS_2026 } from "@/config/config";
import { Image } from "astro:assets";
import "@/styles/2025/global.css";

// This is the root landing page for the site
---

<Layout title="Open Source Day 2026 — Stay Alert" activePath="/">
  <div class="relative min-h-screen flex items-center justify-center overflow-hidden bg-white">
    <!-- Animated Background Blobs -->
    <div class="absolute top-0 -right-4 w-72 h-72 bg-emerald-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 left-20 w-72 h-72 bg-teal-300 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-4000"></div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
      <div class="flex flex-col items-center mb-12 animate-fade-in-up">
        <!-- Status Indicator -->
        <div class="inline-flex items-center space-x-2 px-4 py-2 rounded-full bg-green-50 text-green-700 text-sm font-bold border border-green-100 mb-8 animate-pulse shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          <span>STAY ALERT</span>
        </div>

        <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-6">
          <span class="block text-gray-900">OSD 2026</span>
          <span class="gradient-text italic">IS COMING.</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-600 max-w-2xl mx-auto mb-12 leading-relaxed">
          The next chapter of the ultimate Open Source celebration is being architected. Prepare for impact.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <a
            href="/2025/"
            class="group relative inline-flex items-center justify-center px-8 py-4 font-bold text-white transition-all duration-200 bg-gray-900 font-pj rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 hover:scale-105"
          >
            Explore 2025 Event
            <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Tech Stack Icons / Partners placeholders if needed -->
      <div class="mt-20 pt-10 border-t border-gray-100 flex flex-wrap justify-center gap-8 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
        <div class="text-2xl font-bold text-gray-400">#OSD2026</div>
        <div class="text-2xl font-bold text-gray-400">#OpenSource</div>
        <div class="text-2xl font-bold text-gray-400">#ComingSoon</div>
      </div>
    </div>
  </div>

  <!-- OSD 2026 Get Involved Section -->
  <section class="py-24 px-4 bg-gradient-to-b from-white via-green-50 to-white relative overflow-hidden">
    <!-- Decorative blobs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-20 -left-20 w-96 h-96 bg-green-100 rounded-full opacity-40 blur-3xl"></div>
      <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-emerald-100 rounded-full opacity-40 blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-green-100 text-green-700 text-sm font-bold border border-green-200 mb-6 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </span>
          Forms are LIVE
        </div>
        <h2 class="text-5xl md:text-6xl font-black text-gray-900 mb-5">
          Get Involved in <span class="gradient-text">OSD 2026</span>
        </h2>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
          OSD 2026 is taking shape — and we need <em>you</em>. Whether you want to speak, volunteer, sponsor, or spread the word, there's a place for you here.
        </p>
      </div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {CALLS_2026.map((call) => (
          <a
            href={call.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex flex-col bg-white border border-gray-100 rounded-2xl p-7 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1 overflow-hidden"
          >
            <!-- Gradient accent top bar -->
            <div class={`absolute top-0 left-0 right-0 h-1 bg-gradient-to-r ${call.color} rounded-t-2xl`}></div>

            <!-- Badge -->
            <div class="absolute top-4 right-4">
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full bg-green-50 text-green-700 text-xs font-bold border border-green-200">
                <span class="block w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                {call.badge}
              </span>
            </div>

            <!-- Emoji Icon -->
            <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${call.color} flex items-center justify-center text-2xl mb-5 shadow-md group-hover:scale-110 transition-transform duration-300`}>
              {call.emoji}
            </div>

            <!-- Content -->
            <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-green-700 transition-colors">
              {call.title}
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed flex-1">
              {call.description}
            </p>

            <!-- CTA -->
            <div class="mt-5 flex items-center text-sm font-semibold text-green-600 group-hover:text-green-700">
              Apply Now
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </a>
        ))}
      </div>

      <!-- Bottom note -->
      <p class="text-center text-gray-400 text-sm mt-12">
        All forms open for OSD 2026. Questions? Reach us at
        <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-medium">opensourceweekend@gmail.com</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  /* Custom extra styles for the futuristic feel */
  .gradient-text {
    background: linear-gradient(135deg, #10b981 0%, #3b82f6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
