---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
---

<Layout title="Speakers — Open Source Day 2026" activePath="/speakers">
  <!-- Hero -->
  <div class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-white px-4 py-24">
    <div class="absolute top-0 -right-4 w-80 h-80 bg-violet-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-2000"></div>
    <div class="absolute -bottom-8 -left-4 w-80 h-80 bg-purple-200 rounded-full mix-blend-multiply filter blur-3xl opacity-50 animate-blob animation-delay-4000"></div>

    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <!-- Status badge -->
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-violet-50 text-violet-700 text-sm font-bold border border-violet-200 mb-8 shadow-sm animate-pulse">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-violet-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-violet-500"></span>
        </span>
        APPLICATIONS OPEN
      </div>

      <div class="text-7xl mb-6">🎤</div>

      <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-6">
        <span class="block text-gray-900">OSD 2026</span>
        <span class="block" style="background: linear-gradient(135deg, #7c3aed, #4f46e5); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">SPEAKERS</span>
      </h1>

      <p class="text-xl md:text-2xl text-gray-600 max-w-2xl mx-auto mb-12 leading-relaxed">
        We're looking for passionate speakers to inspire India's open source community at OSD 2026. Got a story, a project, or an idea worth sharing?
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <a
          href="/cfspk"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-2 px-10 py-4 font-bold text-white rounded-full transition-all duration-200 hover:scale-105 shadow-xl"
          style="background: linear-gradient(135deg, #7c3aed, #4f46e5);"
        >
          🎤 Submit Your Talk Proposal
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/2025/speakers"
          class="inline-flex items-center gap-2 px-8 py-4 font-bold text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-full transition-all duration-200 hover:scale-105"
        >
          View 2025 Speakers
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>

      <!-- What we're looking for -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left mt-8">
        <div class="bg-white border border-violet-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all">
          <div class="text-3xl mb-3">💡</div>
          <h3 class="font-bold text-gray-900 mb-2">Talks & Keynotes</h3>
          <p class="text-gray-500 text-sm">20–45 min talks on open source tools, projects, practices, or community stories.</p>
        </div>
        <div class="bg-white border border-violet-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all">
          <div class="text-3xl mb-3">🛠️</div>
          <h3 class="font-bold text-gray-900 mb-2">Workshops</h3>
          <p class="text-gray-500 text-sm">Hands-on sessions where attendees build something real with open source tech.</p>
        </div>
        <div class="bg-white border border-violet-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-all">
          <div class="text-3xl mb-3">🎙️</div>
          <h3 class="font-bold text-gray-900 mb-2">Panel Discussions</h3>
          <p class="text-gray-500 text-sm">Join a curated panel of experts to discuss the future of open source in India.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-gray-950 text-center">
    <p class="text-gray-400 mb-4 text-lg">Questions about speaking? Reach out to us.</p>
    <a href="mailto:opensourceweekend@gmail.com" class="text-violet-400 hover:text-violet-300 font-semibold text-lg hover:underline">
      opensourceweekend@gmail.com
    </a>
  </section>
</Layout>
