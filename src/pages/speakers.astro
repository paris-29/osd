---
import SpeakerCard from "@components/SpeakerCard.astro";
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.jsx";
import Heading from "@components/Heading.astro";
import PersonSVG from "@/assets/icons/square-user.svg";
import { SPEAKERS } from "@/config.ts";
import "@/styles/global.css";

const OSD_YEAR = 2025;

// separate speakers
const currentSpeakers = SPEAKERS.filter((s) => s.eventYear === OSD_YEAR);
const pastSpeakers = SPEAKERS.filter((s) => s.eventYear < OSD_YEAR);
---

<Layout title="Speakers - OpenSource Weekend 2025">
  <!-- Heading Section -->
  <Heading
    title="Our Speakers"
    description="We're always looking for passionate speakers to share their knowledge and experience."
  />

  <!-- Current Year Speakers -->
  <section class="pb-10 px-4">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-700 mb-10 text-left">
        2025 Open Source Day
      </h2>
      <div class="container mx-auto px-4">
        {
          currentSpeakers.length !== 0 ? (
            ""
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 justify-items-center lg:grid-cols-4 gap-8">
              <SpeakerCard
                width={5}
                name="To be announced"
                image={PersonSVG}
                presentationTitle="TBD"
                event=""
                position=""
                company=""
              />

              {Array.from({ length: 3 }, (_, index) => (
                <SpeakerCard
                  width={5}
                  name="To be announced"
                  image={PersonSVG}
                  presentationTitle="TBD"
                  event=""
                  position=""
                  company=""
                  class="hidden md:block lg:block"
                />
              ))}
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Past Speakers -->
  <section class="py-10 px-4 bg-gray-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-800 mb-10 text-left">
        Past Speakers
      </h2>
      <div class="container mx-auto px-4">
        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 justify-items-center lg:grid-cols-4 gap-8"
        >
          {
            pastSpeakers.map((speaker) => (
              <SpeakerCard width={400} {...speaker} />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Call for Speakers -->
  <section class="py-20 px-4 bg-gradient-to-r from-gray-900/50 to-black/50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Want to Speak?
      </h2>
      <p class="text-xl text-gray-200 mb-8">
        We're always looking for passionate speakers to share their knowledge
        and experience.
      </p>
      <a
        href="https://forms.gle/1snXWPXU63xHBMAB6"
        class="inline-block bg-green-500 drop-shadow-2xl hover:bg-green-400 text-black px-8 py-4 rounded-full font-bold text-lg transition-all duration-200 glow-effect hover:scale-105 transform"
      >
        Submit Your Proposal
      </a>
    </div>
  </section>
</Layout>
