---
import Layout from '../components/Layout.astro';
import Navigation from '../components/Navigation.jsx';
import { SPEAKERS } from '../config.ts';
import '../styles/global.css';
---

<Layout title="Speakers - OpenSource Weekend 2025">
  <Navigation client:load />
  
  <!-- Hero Section -->
  <section class="pt-32 pb-20 px-4">
    <div class="max-w-6xl mx-auto text-center">
      <div class="mb-8 flex justify-center">
        <img src="/icons/OSDLogo.svg" alt="Open Source Day Logo" class="w-16 h-16 md:w-20 md:h-20" />
      </div>
      <h1 class="text-5xl md:text-7xl font-bold gradient-text mb-6">Our Speakers</h1>
      <p class="text-xl text-black-300 max-w-3xl mx-auto">
        Learn from industry leaders, open source maintainers, and innovative thinkers 
        who are shaping the future of technology.
      </p>
    </div>
  </section>

  <!-- Speakers Grid -->
  <section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {SPEAKERS.map((speaker) => (
          <div class="bg-gray-900/50 rounded-xl border border-green-500/20 backdrop-blur-sm hover:border-green-500/40 transition-all duration-300 group">
            <div class="aspect-square overflow-hidden rounded-t-xl">
              <img 
                src={speaker.image} 
                alt={speaker.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-bold text-white mb-2">{speaker.name}</h3>
              <p class="text-green-400 font-semibold mb-3">{speaker.title}</p>
              <p class="text-black-300 mb-4">{speaker.bio}</p>
              <div class="border-t border-gray-700 pt-4">
                <p class="text-sm text-black-400 font-medium">Talk:</p>
                <p class="text-white">{speaker.talk}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Call for Speakers -->
  <section class="py-20 px-4 bg-gradient-to-r from-gray-900/50 to-black/50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">Want to Speak?</h2>
      <p class="text-xl text-black-300 mb-8">
        We're always looking for passionate speakers to share their knowledge and experience.
      </p>
      <a
        href="mailto:speakers@opensourceweekend.com"
        class="inline-block bg-green-500 hover:bg-green-400 text-black px-8 py-4 rounded-full font-bold text-lg transition-all duration-200 glow-effect hover:scale-105 transform"
      >
        Submit Your Proposal
      </a>
    </div>
  </section>
</Layout>