---
import Layout from "@/layouts/Layout.astro";
import Heading from "@components/Heading.astro";
import SpeakerCard from "@components/SpeakerCard.astro";
import "@/styles/global.css";

import { SPEAKERS, CURRENT_SPEAKERS } from "@/config.ts";

const OSD_YEAR = 2025;

// separate speakers
const pastSpeakers = SPEAKERS.filter((s) => s.eventYear < OSD_YEAR);
---

<Layout title="Speakers — 2025 OSD" activePath="/speakers">
  <!-- Heading Section -->
  <Heading title="Our Speakers" description="" />

  <!-- Current Year Speakers -->
  <section class="pb-10 px-4">
    <div class="max-w-7xl mx-auto my-4">
      {
        CURRENT_SPEAKERS.map((event) => (
          <div class="mb-5">
            <h2 class="text-4xl font-bold text-left pl-4 mb-12">
              <span class="gradient-text">{event.eventName}</span>
              <span class="text-lg block text-green-500">
                {`At ${event.venue} (${event.date})`}
              </span>
            </h2>
            <div class="container mx-auto px-4 pb-10">
              {event?.speakers && (
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 justify-items-center lg:grid-cols-4 gap-8">
                  {event.speakers.map((speaker) => (
                    <SpeakerCard width={400} {...speaker} />
                  ))}
                </div>
              )}
              {event?.sections && (
                <div>
                  {event.sections.map((section) => (
                    <div class="flex flex-col my-5">
                      <h3 class="text-xl font-bold text-gray-700 mb-5">
                        {section.title}
                      </h3>
                      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 justify-items-center lg:grid-cols-4 gap-8">
                        {section.speakers.map((speaker) => (
                          <SpeakerCard width={400} {...speaker} />
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Past Speakers -->
  <section class="py-10 px-4 bg-gray-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-800 mb-5 text-left">
        Past Speakers
      </h2>
      <div class="container mx-auto px-4">
        <div
          class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 justify-items-center lg:grid-cols-4 gap-8"
        >
          {
            pastSpeakers.map((speaker) => (
              <SpeakerCard width={400} {...speaker} />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Call for Speakers -->
  <section class="py-20 px-4 bg-gradient-to-r from-gray-900/50 to-black/50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Want to Speak?
      </h2>
      <p class="text-xl text-gray-200 mb-8">
        We're always looking for passionate speakers to share their knowledge
        and experience.
      </p>
      <a
        href="https://forms.gle/1snXWPXU63xHBMAB6"
        class="inline-block bg-green-500 drop-shadow-2xl hover:bg-green-400 text-white px-8 py-4 rounded-full font-bold text-lg transition-all duration-200 glow-effect hover:scale-105 transform"
      >
        Submit Your Proposal
      </a>
    </div>
  </section>
</Layout>
