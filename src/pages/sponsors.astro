---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
import PageHero from "@/components/PageHero.jsx";
import { sponsorsData } from "@/lib/graphql/queries/sponsors.query.ts";
import type { SponsorGroup } from "@/types/sponsors.types.ts";
import { env } from "@/lib/env.ts";

const rawGroups: SponsorGroup[] = sponsorsData?.sponsors?.[0]?.sponsors ?? [];

const groups = rawGroups.map((group) => ({
  ...group,
  sponsors: group.sponsors.map((s) => ({
    ...s,
    logoUrl: s.logo?.url ? `${env.STRAPI_BASE_URL}${s.logo.url}`: null,
  })),
}));

const STATS = [
  { value: "1000+", label: "Attendees" },
  { value: "30+", label: "Sessions" },
  { value: "80+", label: "Partners" },
  { value: "5 yrs", label: "Running" },
];

const TIERS = [
  {
    name: "Platinum",
    tagline: "Maximum visibility & reach",
    perks: [
      "Headline keynote slot (45 min)",
      "Logo on all materials & stage",
      "Premium exhibition booth",
      "20 complimentary passes",
      "Dedicated social campaign",
      "Post-event blog feature",
    ],
    popular: false,
    cta: "Contact Us",
  },
  {
    name: "Gold",
    tagline: "Best value — most popular",
    perks: [
      "Speaking slot (20 min talk)",
      "Logo on website, stage & materials",
      "Exhibition booth",
      "10 complimentary passes",
      "Social media shoutouts (3×)",
    ],
    popular: true,
    cta: "Become a Sponsor",
  },
  {
    name: "Silver",
    tagline: "Essential sponsorship",
    perks: [
      "Logo on website & backdrop",
      "Social media mention (1×)",
      "Shared booth space",
      "5 complimentary passes",
    ],
    popular: false,
    cta: "Contact Us",
  },
];
---

<Layout title="Sponsors — Open Source Day 2026" activePath="/sponsors">

  <!-- Hero -->
  <PageHero client:load
    badge="APPLICATIONS OPEN"
    title="OSD 2026"
    titleGradient="SPONSORS"
    subtitle="Support India's biggest open source event and get your brand in front of 1000+ developers and builders."
    primaryCta={{ text: "Become a Sponsor", href: "/cfs", external: true }}
    secondaryCta={{ text: "Community Partner", href: "/cfc", external: true }}
  />

  <!-- Stats -->
  <section class="py-14 px-4 bg-gray-50 border-y border-gray-100">
    <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-4">
      {STATS.map(({ value, label }) => (
        <div class="text-center border border-gray-100 bg-white rounded-2xl py-6 px-4">
          <div class="text-3xl font-black gradient-text">{value}</div>
          <div class="text-gray-500 text-sm mt-1">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════ CURRENT SPONSORS (real data) ═══════════════ -->
  {groups.length > 0 && (
    <section class="py-20 px-4 bg-white">
      <div class="max-w-6xl mx-auto">
        <!-- Section header -->
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">
            Sponsors &amp; <span class="gradient-text">Community Partners</span>
          </h2>
          <p class="text-gray-500">We're grateful for the support of our partners.</p>
        </div>

        {groups.map((group) => (
          <div class="mb-14 last:mb-0">
            <!-- Section divider with title -->
            <div class="flex items-center gap-4 mb-8">
              <div class="h-px flex-1 bg-gradient-to-r from-transparent to-green-200"></div>
              <span class="text-xs font-bold text-green-700 uppercase tracking-widest px-3 py-1 rounded-full border border-green-200 bg-green-50">
                {group.title}
              </span>
              <div class="h-px flex-1 bg-gradient-to-l from-transparent to-green-200"></div>
            </div>

            <!-- Sponsor logo grid -->
            <div class={`grid gap-5 ${
              group.sponsors.length === 1
                ? "grid-cols-1 max-w-xs mx-auto"
                : group.sponsors.length === 2
                ? "grid-cols-1 sm:grid-cols-2 max-w-xl mx-auto"
                : "grid-cols-1 sm:grid-cols-2 md:grid-cols-3"
            }`}>
              {group.sponsors.map((sponsor) => (
                <a
                  href={sponsor.website && sponsor.website !== "#" ? sponsor.website : undefined}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`group relative bg-white border border-gray-100 rounded-2xl p-8 flex flex-col items-center justify-center gap-4 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-green-200 ${sponsor.website && sponsor.website !== "#" ? "cursor-pointer" : "cursor-default"}`}
                >
                  <!-- Subtle top accent -->
                  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-green-400 to-emerald-500 rounded-t-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>

                  {sponsor.logoUrl ? (
                    <img
                      src={sponsor.logoUrl}
                      alt={`${sponsor.name} logo`}
                      loading="lazy"
                      class="max-h-20 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
                    />
                  ) : (
                    <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-green-100 to-emerald-200 flex items-center justify-center">
                      <span class="text-green-700 font-black text-xl">
                        {sponsor.name.charAt(0)}
                      </span>
                    </div>
                  )}

                  <span class="text-sm font-semibold text-gray-600 group-hover:text-green-700 transition-colors text-center">
                    {sponsor.name}
                  </span>

                  {sponsor.website && sponsor.website !== "#" && (
                    <span class="text-xs text-gray-300 group-hover:text-green-400 flex items-center gap-1 transition-colors">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                      Visit website
                    </span>
                  )}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ═══════════════ SPONSORSHIP TIERS ═══════════════ -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">
          Sponsorship <span class="gradient-text">Tiers</span>
        </h2>
        <p class="text-gray-500">Pick a tier that fits your goals</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch">
        {TIERS.map((tier) => (
          <div class={`relative bg-white rounded-2xl p-8 flex flex-col transition-all duration-300 hover:shadow-lg hover:-translate-y-1 ${tier.popular ? "border-2 border-green-300" : "border border-gray-200"}`}>

            {tier.popular && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="bg-gray-900 text-white text-xs font-bold px-4 py-1.5 rounded-full whitespace-nowrap">MOST POPULAR</span>
              </div>
            )}

            <h3 class="text-2xl font-black text-gray-900 mt-2 mb-1">{tier.name}</h3>
            <p class="text-gray-400 text-sm mb-6">{tier.tagline}</p>

            <ul class="space-y-3 mb-8 flex-1">
              {tier.perks.map((perk) => (
                <li class="flex items-start gap-2.5 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-green-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  {perk}
                </li>
              ))}
            </ul>

            <a
              href="/cfs"
              target="_blank"
              rel="noopener noreferrer"
              class={`block w-full text-center py-3 rounded-full font-bold text-sm transition-all hover:scale-105 ${tier.popular ? "bg-gray-900 hover:bg-gray-800 text-white" : "border-2 border-gray-200 hover:border-gray-900 text-gray-700"}`}
            >
              {tier.cta}
            </a>
          </div>
        ))}
      </div>

      <p class="text-center text-gray-400 text-sm mt-8">
        Custom packages available —{" "}
        <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline">reach out to discuss</a>.
      </p>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-white text-center border-t border-gray-100">
    <h3 class="text-2xl font-black text-gray-900 mb-3">
      Interested in <span class="gradient-text">sponsoring?</span>
    </h3>
    <p class="text-gray-500 mb-6 max-w-md mx-auto">
      We'd love to partner with you. Drop us a line and let's make it happen.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/cfs" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105">
        Apply to Sponsor
      </a>
      <a href="mailto:opensourceweekend@gmail.com"
        class="font-semibold text-gray-500 hover:text-gray-900 transition-colors">
        opensourceweekend@gmail.com
      </a>
    </div>
  </section>

</Layout>
