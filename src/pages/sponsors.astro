---
import Layout from '../components/Layout.astro';
import Navigation from '../components/Navigation.jsx';
import Footer from '../components/Footer.jsx';
import SponsorsGrid from '../components/SponsorsGrid.jsx';
import { COMMUNITY_PARTNERS ,SPONSOR_TIERS} from '../config.ts';
import '../styles/global.css';
---

<Layout title="Sponsors - Open Source Day 2025">
  <Navigation client:load />

  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-block text-center">
          <div class="flex items-center justify-center gap-3">
            <img src="/icons/OSDLogo.svg" alt="OSD" class="w-10 h-10" />
            <h1 class="text-4xl font-bold text-green-600">Sponsors & Community Partners</h1>
          </div>
          <div class="w-32 h-1 mx-auto mt-6 rounded-full bg-gradient-to-r from-green-300 to-green-500"></div>
        </div>
        <p class="text-gray-600 mt-2">We’re grateful for the support of our partners.</p>
      </div>

      <div class="mb-12">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-200"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">Sponsors</h2>
          </div>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
        <!-- temporarily show community partner images in Sponsors grid (plain images only) -->
        <SponsorsGrid client:load sponsors={SPONSOR_TIERS.gold} columns={3} maxHeight={140} />
      </div>

      <div class="mb-8">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-200"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">Community Partners</h2>
          </div>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
        <SponsorsGrid client:load sponsors={COMMUNITY_PARTNERS} columns={6} maxHeight={140} />
      </div>

  
    </div>
  </section>

  <Footer client:load />
</Layout>
