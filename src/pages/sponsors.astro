---
import Layout from "@/layouts/Layout.astro";
import Navigation from "@/components/Navigation.jsx";
import SponsorsGrid from "@/components/SponsorsGrid.jsx";
import Heading from "@components/Heading.astro";
import { COMMUNITY_PARTNERS, SPONSOR_TIERS } from "@/config.ts";
import "@/styles/global.css";
---

<Layout title="Sponsors - Open Source Day 2025">
  <Navigation client:load activePath="/sponsors" />

  <!-- Heading Section -->
  <Heading
    title="Sponsors & Community Partners"
    description="We’re grateful for the support of our partners."
    client:load
  />

  <section class="py-12 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-200"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">
              Sponsors
            </h2>
          </div>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
        <!-- temporarily show community partner images in Sponsors grid (plain images only) -->
        <SponsorsGrid
          client:load
          sponsors={SPONSOR_TIERS.gold}
          columns={3}
          maxHeight={140}
        />
      </div>

      <div class="mb-8">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-200"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">
              Community Partners
            </h2>
          </div>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
        <SponsorsGrid
          client:load
          sponsors={COMMUNITY_PARTNERS}
          columns={6}
          maxHeight={140}
        />
      </div>
    </div>
  </section>
</Layout>
