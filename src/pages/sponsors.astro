---
import Layout from "@/layouts/Layout.astro";
import SponsorsGrid from "@/components/SponsorsGrid.jsx";
import Heading from "@components/Heading.astro";
import "@/styles/global.css";

import {
  VENUE_PARTNER,
  COMMUNITY_PARTNERS,
  SPONSOR_TIERS,
  EVENT_PARTNER,
} from "@/config.ts";
---

<Layout title="Sponsors — 2025 OSD" activePath="/sponsors">
  <!-- Heading Section -->
  <Heading
    title="Sponsors & Community Partners"
    description="We’re grateful for the support of our partners."
  />

  <section class="py-12 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-500"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">
              Sponsors
            </h2>
          </div>
          <div class="flex-1 h-px bg-gray-500"></div>
        </div>
        <!-- temporarily show community partner images in Sponsors grid (plain images only) -->
        <SponsorsGrid
          client:load
          sponsors={SPONSOR_TIERS.gold}
          columns={3}
          maxHeight={140}
        />
      </div>
      <div class="mb-12">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-500"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">
              Venue Partner
            </h2>
          </div>
          <div class="flex-1 h-px bg-gray-500"></div>
        </div>
        <SponsorsGrid
          client:load
          sponsors={VENUE_PARTNER}
          columns={1}
          maxHeight={140}
        />
      </div>

      <!-- Event Partner -->
      <div class="mb-12">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-500"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">
              Event Partner
            </h2>
          </div>
          <div class="flex-1 h-px bg-gray-500"></div>
        </div>
        <SponsorsGrid
          client:load
          sponsors={EVENT_PARTNER}
          columns={1}
          maxHeight={140}
        />
      </div>

      <div class="mb-8">
        <div class="flex items-center mb-6">
          <div class="flex-1 h-px bg-gray-500"></div>
          <div class="px-4 text-center">
            <h2 class="text-2xl font-semibold text-gray-800 inline-block">
              Community Partners
            </h2>
          </div>
          <div class="flex-1 h-px bg-gray-500"></div>
        </div>
        <SponsorsGrid
          client:load
          sponsors={COMMUNITY_PARTNERS}
          columns={{ base: 2, md: 4, lg: 6 }}
          maxHeight={140}
        />
      </div>
    </div>
  </section>
</Layout>
