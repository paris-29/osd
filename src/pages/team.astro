---
import PageHero from "@/components/PageHero.jsx";
import Layout from "@/layouts/Layout.astro";
import { teamsData } from "@/lib/graphql/queries/teams.query.ts";
import { env } from "@/lib/env.ts";
import type { ResolvedTeamGroup, ResolvedTeamMember } from "@/types/teams.types.ts";
import "@/styles/2025/global.css";

// Build full image URLs and resolve groups
const rawGroups = teamsData?.teams?.[0]?.teams ?? [];

const groups: ResolvedTeamGroup[] = rawGroups.map((group) => ({
  ...group,
  teams: group.teams.map((member) => ({
    ...member,
    imageUrl: member.image?.url
      ? member.image.url.startsWith("http")
        ? member.image.url
        : `${env.STRAPI_BASE_URL}${member.image.url}`
      : null,
  })),
}));
---

<Layout title="Team — Open Source Day 2026" activePath="/team">

  <!-- Hero -->
  <PageHero
    client:load
    badge="VOLUNTEER APPLICATIONS OPEN"
    title="MEET THE"
    titleGradient="OSD 2026 TEAM"
    subtitle="Volunteers are the heartbeat of Open Source Day. Join the 2026 crew and help create something legendary."
    primaryCta={{ text: "Apply to Volunteer", href: "/cfv", external: true }}
    secondaryCta={{ text: "View 2025 Team", href: "/2025/team" }}
  />

  <!-- ═══════════════ TEAM GROUPS (real data) ═══════════════ -->
  {groups.length > 0 && (
    <section class="py-20 px-4 bg-white">
      <div class="max-w-6xl mx-auto space-y-20">
        {groups.map((group) => (
          <div>
            <!-- Group header divider -->
            <div class="flex items-center gap-4 mb-10">
              <div class="h-px flex-1 bg-gradient-to-r from-transparent to-green-200"></div>
              <div class="text-center">
                <span class="text-xs font-bold text-green-700 uppercase tracking-widest px-4 py-1.5 rounded-full border border-green-200 bg-green-50">
                  {group.title}
                </span>
              </div>
              <div class="h-px flex-1 bg-gradient-to-l from-transparent to-green-200"></div>
            </div>

            <!-- Member cards -->
            <div class={`grid gap-5 ${
              group.teams.length === 1
                ? "grid-cols-1 max-w-[260px] mx-auto"
                : group.teams.length === 2
                ? "grid-cols-2 max-w-xl mx-auto"
                : group.teams.length <= 4
                ? "grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
                : "grid-cols-2 sm:grid-cols-3 md:grid-cols-4"
            }`}>
              {group.teams.map((member: ResolvedTeamMember) => (
                <a
                  href={member.linkedin || undefined}
                  target={member.linkedin ? "_blank" : undefined}
                  rel="noopener noreferrer"
                  class={`group relative bg-white border border-gray-100 rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 hover:border-green-200 flex flex-col ${member.linkedin ? "cursor-pointer" : "cursor-default"}`}
                >
                  <!-- Top accent bar on hover -->
                  <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-green-400 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-20"></div>

                  <!-- Photo area — portrait top half -->
                  <div class="relative w-full aspect-[4/5] bg-gradient-to-br from-green-50 to-emerald-100 overflow-hidden">
                    {member.imageUrl ? (
                      <img
                        src={member.imageUrl}
                        alt={member.name}
                        loading="lazy"
                        class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="absolute inset-0 flex items-center justify-center">
                        <span class="text-5xl font-black text-green-200 select-none">{member.name.charAt(0)}</span>
                      </div>
                    )}

                    <!-- Gradient scrim at bottom of photo -->
                    <div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>

                    <!-- LinkedIn slide-up panel -->
                    {member.linkedin && (
                      <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out bg-green-500/95 backdrop-blur-sm flex items-center justify-center gap-2 py-3 z-10">
                        <svg class="w-4 h-4 text-white shrink-0" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                        <span class="text-white text-xs font-bold">View Profile</span>
                      </div>
                    )}
                  </div>

                  <!-- Text info below photo -->
                  <div class="p-4 flex flex-col gap-1.5">
                    <h3 class="font-bold text-gray-900 text-sm leading-snug group-hover:text-green-700 transition-colors line-clamp-2">
                      {member.name}
                    </h3>
                    {member.roles.length > 0 && (
                      <div class="flex flex-wrap gap-1">
                        <!-- Primary role as badge -->
                        <span class="text-xs px-2 py-0.5 rounded-full font-semibold bg-green-50 text-green-700 border border-green-100 leading-snug">
                          {member.roles[0].role.trim()}
                        </span>
                        <!-- Extra roles as plain text -->
                        {member.roles.slice(1).map((r) => (
                          <span class="text-xs text-gray-400 leading-snug self-center">
                            · {r.role.trim()}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              ))}
            </div>

          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Volunteer Roles -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Volunteer <span class="gradient-text">Roles</span></h2>
        <p class="text-gray-500">Find the role that fits your skills and passion</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: "Event Coordination",
            desc: "Help plan sessions, manage timelines, and keep the event running smoothly.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />`,
          },
          {
            title: "Marketing & Outreach",
            desc: "Spread the word, manage social media, and grow the OSD 2026 community.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 1 8.835-2.535m0 0A23.74 23.74 0 0 1 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />`,
          },
          {
            title: "Technical Support",
            desc: "Support AV, live streaming, registration systems, and on-the-day tech.",
            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />`,
          },
        ].map(({ title, desc, icon }) => (
          <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-7 rounded-2xl transition-all duration-300">
            <div class="w-10 h-10 mb-4 text-green-600">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" set:html={icon} />
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-white text-center border-t border-gray-100">
    <h3 class="text-2xl font-black text-gray-900 mb-3">
      Want to <span class="gradient-text">join the team?</span>
    </h3>
    <p class="text-gray-500 mb-6 max-w-md mx-auto">
      We'd love to have you on board. Apply to volunteer or reach out to us directly.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/cfv"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105"
      >
        Apply to Volunteer
      </a>
      <a
        href="mailto:opensourceweekend@gmail.com"
        class="font-semibold text-gray-500 hover:text-gray-900 transition-colors"
      >
        opensourceweekend@gmail.com
      </a>
    </div>
  </section>

</Layout>
