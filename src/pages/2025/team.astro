---
import { Image } from "astro:assets";

import Layout from "@/layouts/2025/Layout.astro";
import Heading from "@components/2025/Heading.astro";
import "@/styles/2025/global.css";

import { TEAM } from "@/config/2025/config";

// Helper: normalize roles to an array and safely read linkedin
const getRoles = (m: any): string[] => {
  if (Array.isArray(m.roles)) return m.roles as string[];
  if (m.role) return [m.role];
  return [];
};

const getLinkedin = (m: any): string | null => {
  return m && m.linkedin ? m.linkedin : null;
};
---

<Layout title="Team — 2025 OSD" activePath="/2025/team">
  <!-- OSD 2026 Call for Volunteers Banner -->
  <div class="bg-gradient-to-r from-emerald-600 to-green-700 text-white py-5 px-4">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="text-3xl">🙌</span>
        <div>
          <div class="font-black text-lg md:text-xl">OSD 2026 — Volunteer Applications Open!</div>
          <div class="text-green-200 text-sm">Join the team that makes Open Source Day happen. We'd love to have you!</div>
        </div>
      </div>
      <a
        href="/cfv"
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 inline-flex items-center gap-2 bg-white text-green-700 font-bold px-6 py-2.5 rounded-full hover:bg-green-50 transition-all duration-200 hover:scale-105 shadow-lg text-sm"
      >
        Apply to Volunteer
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </div>

  <!-- Heading Section -->
  <Heading
    title="Our Team"
    description="Meet the people who make Open Source Day possible."
  />

  <section class="py-12 px-4 bg-gradient-to-t from-green-200 to-green-50">
    <div class="max-w-6xl mx-auto">
      <div class="space-y-12">
        {
          TEAM.advisory && (
            <div>
              <h2 class="text-2xl font-semibold mb-6">Advisory Council</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {TEAM.advisory.map((m) =>
                  getLinkedin(m) ? (
                    <a
                      href={getLinkedin(m)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block h-full"
                    >
                      <div class="bg-white p-6 rounded-lg shadow-sm text-center hover:shadow-md transition-shadow h-full">
                        <Image
                          src={m.image}
                          alt={m.name}
                          class="w-28 h-28 rounded-full mx-auto object-cover mb-4"
                          width={400}
                        />
                        <h3 class="font-semibold text-lg">{m.name}</h3>
                        <div class="text-sm text-gray-600">
                          {getRoles(m).map((r: string) => (
                            <div>{r}</div>
                          ))}
                        </div>
                      </div>
                    </a>
                  ) : (
                    <div class="bg-white p-6 rounded-lg shadow-sm text-center h-full">
                      <Image
                        src={m.image}
                        alt={m.name}
                        class="w-28 h-28 rounded-full mx-auto object-cover mb-4"
                        width={400}
                      />
                      <h3 class="font-semibold text-lg">{m.name}</h3>
                      <div class="text-sm text-gray-600">
                        {getRoles(m).map((r: string) => (
                          <div>{r}</div>
                        ))}
                      </div>
                    </div>
                  )
                )}
              </div>
            </div>
          )
        }

        {
          TEAM.mentors && (
            <div>
              <h2 class="text-2xl font-semibold mb-6">Mentor Board</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {TEAM.mentors.map((m) =>
                  getLinkedin(m) ? (
                    <a
                      href={getLinkedin(m)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block h-full"
                    >
                      <div class="bg-white p-6 rounded-lg shadow-sm text-center hover:shadow-md transition-shadow h-full">
                        <Image
                          src={m.image}
                          alt={m.name}
                          class="w-24 h-24 rounded-full mx-auto object-cover mb-4"
                          width={400}
                        />
                        <h3 class="font-semibold">{m.name}</h3>
                        <div class="text-sm text-gray-600">
                          {getRoles(m).map((r: string) => (
                            <div>{r}</div>
                          ))}
                        </div>
                      </div>
                    </a>
                  ) : (
                    <div class="bg-white p-6 rounded-lg shadow-sm text-center hover:shadow-md transition-shadow h-full">
                      <Image
                        src={m.image}
                        alt={m.name}
                        class="w-24 h-24 rounded-full mx-auto object-cover mb-4"
                        width={400}
                      />
                      <h3 class="font-semibold">{m.name}</h3>
                      <div class="text-sm text-gray-600">
                        {getRoles(m).map((r: string) => (
                          <div>{r}</div>
                        ))}
                      </div>
                    </div>
                  )
                )}
              </div>
            </div>
          )
        }

        {
          TEAM.core && (
            <div>
              <h2 class="text-2xl font-semibold mb-6">Core Team</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {TEAM.core.map((m) =>
                  getLinkedin(m) ? (
                    <a
                      href={getLinkedin(m)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block h-full"
                    >
                      <div class="bg-white p-6 rounded-lg shadow-sm text-center hover:shadow-md transition-shadow h-full">
                        <Image
                          src={m.image}
                          alt={m.name}
                          class="w-20 h-20 rounded-full mx-auto object-cover mb-4"
                          width={400}
                        />
                        <h3 class="font-semibold">{m.name}</h3>
                        <div class="text-sm text-gray-600">
                          {getRoles(m).map((r: string) => (
                            <div>{r}</div>
                          ))}
                        </div>
                      </div>
                    </a>
                  ) : (
                    <div class="bg-white p-6 rounded-lg shadow-sm text-center h-full">
                      <Image
                        src={m.image}
                        alt={m.name}
                        class="w-20 h-20 rounded-full mx-auto object-cover mb-4"
                        width={400}
                      />
                      <h3 class="font-semibold">{m.name}</h3>
                      <div class="text-sm text-gray-600">
                        {getRoles(m).map((r: string) => (
                          <div>{r}</div>
                        ))}
                      </div>
                    </div>
                  )
                )}
              </div>
            </div>
          )
        }

        {
          TEAM.volunteers && (
            <div>
              <h2 class="text-2xl font-semibold mb-6">Volunteers</h2>
              <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                {TEAM.volunteers.map((m) =>
                  getLinkedin(m) ? (
                    <a
                      href={getLinkedin(m)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block h-full"
                    >
                      <div class="bg-white p-4 rounded-lg shadow-sm text-center hover:shadow-md transition-shadow h-full">
                        <Image
                          src={m.image}
                          alt={m.name}
                          class="w-20 h-20 rounded-full mx-auto object-cover mb-3"
                          width={400}
                        />
                        <div class="font-medium">{m.name}</div>
                        <div class="text-sm text-gray-600">
                          {getRoles(m).map((r: string) => (
                            <div>{r}</div>
                          ))}
                        </div>
                      </div>
                    </a>
                  ) : (
                    <div class="bg-white p-4 rounded-lg shadow-sm text-center h-full">
                      <Image
                        src={m.image}
                        alt={m.name}
                        class="w-20 h-20 rounded-full mx-auto object-cover mb-3"
                        width={400}
                      />
                      <div class="font-medium">{m.name}</div>
                      <div class="text-sm text-gray-600">
                        {getRoles(m).map((r) => (
                          <div>{r}</div>
                        ))}
                      </div>
                    </div>
                  )
                )}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Join as Volunteer OSD 2026 -->
  <section class="py-20 px-4 bg-gradient-to-br from-gray-950 via-emerald-950 to-gray-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 50%, #059669 0%, transparent 50%), radial-gradient(circle at 80% 50%, #10b981 0%, transparent 50%);"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/20 border border-emerald-400/30 text-emerald-300 text-sm font-semibold mb-6">
        <span class="block w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
        OSD 2026 — Volunteer Applications Open
      </div>
      <div class="text-5xl mb-4">🙌</div>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-5">
        Want to be Part of the OSD 2026 Team?
      </h2>
      <p class="text-xl text-gray-300 mb-10 max-w-2xl mx-auto leading-relaxed">
        Volunteers are the heart of Open Source Day. Join us to help organize, coordinate, and make OSD 2026 a legendary experience.
      </p>
      <a
        href="/cfv"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-white px-10 py-4 rounded-full font-bold text-lg transition-all duration-200 hover:scale-105 shadow-xl shadow-emerald-900/50"
      >
        Apply to Volunteer
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </section>
</Layout>
