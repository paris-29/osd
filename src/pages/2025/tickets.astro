---
import Layout from "@/layouts/2025/Layout.astro";
import Heading from "@components/2025/Heading.astro";
import CountdownTimer from "@components/2025/CountdownTimer";
import "@/styles/2025/global.css";

import { TICKETS, eventEnded } from "@/config/2025/config";
---

<Layout title="Tickets — 2025 OSD" activePath="/2025/tickets">
  <!-- Heading Section -->
  <Heading title="Get Your Tickets" description="" />

  <!-- Pricing Cards -->

  <section class="py-5 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          TICKETS.map((ticket) => (
            <div
              class={`relative light-card rounded-xl p-8 transition-all duration-300 hover:scale-102 flex flex-col justify-between items-center ${
                ticket.popular
                  ? "border-green-500 ring-2 ring-green-500/20 shadow-green-200 shadow-2xl"
                  : "hover:border-green-500/40"
              }`}
            >
              {ticket.alert && (
                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                  <span
                    class={`px-4 py-2 rounded-full text-sm font-bold ${
                      ticket.alert.classes
                    }`}
                  >
                    {ticket.alert.text || "Most Popular"}
                  </span>
                </div>
              )}

              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-black mb-2">
                  {ticket.name}
                </h3>
                {ticket.subtitle && (
                  <h3 class="text-md text-green-500">{ticket.subtitle}</h3>
                )}
                <p class="text-black mb-4">{ticket.description}</p>

                {/* Updated pricing section */}
                <div class="flex flex-col items-center justify-center space-y-2">
                  {ticket.discountedPrice ? (
                    <>
                      {/* Original price with strikethrough */}
                      <span class="text-2xl text-gray-500 line-through">
                        {ticket.price}
                      </span>
                      {/* Discounted price */}
                      <span class="text-4xl font-bold gradient-text">
                        {ticket.discountedPrice}
                      </span>
                      {/* Coupon code */}
                      {ticket.couponCode && (
                        <div class="bg-yellow-100 border border-yellow-400 rounded-lg px-3 py-2 mt-2">
                          <span class="text-sm font-bold text-yellow-800">
                            Use Code: {ticket.couponCode}
                          </span>
                        </div>
                      )}
                    </>
                  ) : (
                    /* Regular pricing for tickets without discount */ <div class="flex items-center justify-center space-x-2">
                      {ticket.originalPrice && (
                        <span class="text-2xl text-gray-500 line-through">
                          {ticket.originalPrice}
                        </span>
                      )}
                      <span class="text-4xl font-bold gradient-text">
                        {ticket.price}
                      </span>
                    </div>
                  )}
                </div>
              </div>

              <ul class="space-y-3 mb-8">
                {ticket.features.map((feature) => (
                  <li class="flex items-center space-x-3">
                    <svg
                      class="w-5 h-5 text-green-400 flex-shrink-0"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    <span class="text-black">{feature}</span>
                  </li>
                ))}
              </ul>

              {/* Button logic: show disabled button if eventEnded is true */}
              {eventEnded ? (
                <button
                  class={`block w-full py-4 rounded-full font-bold text-lg transition-all duration-200 text-center ${
                    ticket.popular
                      ? "bg-gradient-to-r from-yellow-200 via-emerald-300 via-60% to-green-500 text-black shadow-2xl ring-2 ring-yellow-100/60 glow-effect pointer-events-none opacity-60 cursor-not-allowed"
                      : "border-2 border-green-500 text-green-400 pointer-events-none opacity-60 cursor-not-allowed"
                  }`}
                  aria-disabled="true"
                  tabindex={-1}
                  disabled
                  type="button"
                >
                  Event has ended
                </button>
              ) : (
                // ...existing button logic for active tickets...
                <a
                  href={ticket.konfhubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`block w-full py-4 rounded-full font-bold text-lg transition-all duration-200 text-center ${
                    ticket.popular
                      ? "bg-gradient-to-r from-yellow-200 via-emerald-300 via-60% to-green-500 text-black shadow-2xl ring-2 ring-yellow-100/60 glow-effect"
                      : "border-2 border-green-500 text-green-400"
                  }`}
                >
                  {ticket.linkText || "Register Now"}
                </a>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Countdown appears here -->
  <div class="mt-5 py-16 px-4 bg-gradient-to-r from-green-50 to-green-100">
    <div class="max-w-5xl mx-auto text-center">
      <CountdownTimer client:load />
    </div>
  </div>
</Layout>
