---
import Layout from "@/layouts/2025/Layout.astro";
import Heading from "@components/2025/Heading.astro";
import VenueGallery from "@/components/2025/VenueGallery";
import "@/styles/2025/global.css";

import Location from "@/assets/icons/location.svg";
import CalendarClock from "@/assets/icons/calendarClock.svg";
import LayoutList from "@/assets/icons/layoutList.svg";
import SOU from "@/assets/2025/partners/Silver Oak University.png";
import { Image } from "astro:assets";
---

<Layout title="Venue — 2025 OSD" activePath="/2025/venue">
  <!-- Heading Section -->
  <Heading title="The Venue" />

  <!-- SOU Overview Card -->
  <section class="py-10 px-4 bg-white">
    <div
      class="max-w-6xl mx-auto bg-gradient-to-r from-green-50 to-emerald-50 border border-green-100 rounded-3xl shadow-md flex flex-col md:flex-row items-center gap-6 p-6 md:p-10"
    >
      <Image src={SOU} class="w-60" alt="Silver Oak University" />
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-green-700 mb-3">
          Silver Oak University (SOU)
        </h2>
        <p class="text-gray-800 text-base md:text-lg leading-relaxed max-w-3xl">
          Silver Oak University (SOU) is a premier private university,
          continuing the legacy of the Silver Oak Group of Institutes. Guided by
          its motto,
          <span class="italic">“Gyanam Param Bhushanam”</span> (“Knowledge is
          the highest virtue”), SOU offers a dynamic and inspiring environment
          for tech enthusiasts. The state-of-the-art campus features a
          futuristic curriculum, advanced technology, eminent faculty, strong
          industry-academia connections, and ample career opportunities - making
          it the perfect venue for innovation and collaboration.
        </p>
      </div>
    </div>
  </section>

  <!-- Venue Photos -->
  <section class="py-10 px-4 bg-white">
    <VenueGallery client:load />
  </section>

  <!-- Venue Details -->
  <section class="py-12 px-4 bg-white">
    <div
      class="max-w-6xl mx-auto bg-white rounded-3xl shadow-xl flex flex-col lg:flex-row overflow-hidden border border-gray-100"
    >
      <!-- Left: Venue Details -->
      <div class="lg:w-1/2 p-6 md:p-8 flex flex-col justify-center bg-white">
        <h2 class="text-2xl md:text-3xl font-bold text-green-600 mb-6">
          Venue Details
        </h2>
        <div class="flex items-start gap-4 mb-6">
          <div
            class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0"
          >
            <Location />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-1">Location</h3>
            <p class="text-gray-700">
              <a
                href="https://maps.app.goo.gl/A3NanjxtBwtiqJQK8"
                target="_blank"
                rel="noopener"
                class="text-green-700">Silver Oak University</a
              ><br />
               370/371, near Bhavik Publication, Gota Gam, Gota, Ahmedabad,
              Gujarat 382481<br />
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 mb-6">
          <div
            class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0"
          >
            <CalendarClock />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-1">Date & Time</h3>
            <p class="text-gray-700">
              October 05, 2025<br />
               9:00 AM - 6:00 PM<br />
              <span class="text-sm text-gray-500">Full day event</span>
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div
            class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0"
          >
            <LayoutList />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-1">Accessibility</h3>
            <ul class="list-disc list-inside text-gray-700 text-base">
              <li>Wheelchair accessible venue</li>
              <li>Public transport connectivity</li>
              <li>Parking facilities available</li>
            </ul>
          </div>
        </div>
      </div>
      <!-- Divider -->
      <div class="hidden lg:block w-px bg-gray-100"></div>
      <!-- Right: Venue Features -->
      <div class="lg:w-1/2 p-6 md:p-8 bg-gray-50 flex flex-col justify-center">
        <h2 class="text-2xl md:text-3xl font-bold text-green-600 mb-6">
          Venue Features
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >A</span
            >
            <span class="text-gray-800">Main Auditorium (600 seats)</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >W</span
            >
            <span class="text-gray-800">5 Workshop Rooms</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >E</span
            >
            <span class="text-gray-800">Exhibition Hall</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >N</span
            >
            <span class="text-gray-800">Networking Lounge</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >W</span
            >
            <span class="text-gray-800">High-Speed WiFi</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >L</span
            >
            <span class="text-gray-800">Live Streaming Setup</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >F</span
            >
            <span class="text-gray-800">Food Court</span>
          </div>
          <div class="flex items-center gap-3">
            <span
              class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >A</span
            >
            <span class="text-gray-800">Accessibility Features</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Transport & Connectivity -->
  <section class="pb-16 px-4 bg-white">
    <div
      class="max-w-6xl mx-auto bg-white rounded-3xl shadow-xl border border-gray-100 p-6 md:p-10"
    >
      <div class="flex items-center justify-between gap-4 mb-6 md:mb-8">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold text-green-700">
            Transport & Connectivity
          </h2>
          <p class="text-gray-700 mt-2">
            Convenient access via city buses, metro, rail, and air.
          </p>
        </div>
        <a
          href="https://maps.app.goo.gl/A3NanjxtBwtiqJQK8"
          target="_blank"
          rel="noopener"
          class="hidden sm:inline-block text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg px-4 py-2"
          >Get Directions</a
        >
      </div>
      <div
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6"
      >
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-colors"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center text-white text-lg"
            >🚌</span
          >
          <div>
            <p class="text-black font-semibold">AMTS Bus Stop</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>Silver Oak University</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >100 m</span
              >
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-colors"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center text-white text-lg"
            >🚍</span
          >
          <div>
            <p class="text-black font-semibold">BRTS Bus Stop</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>Gota Cross Road</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >1.2 km</span
              >
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg_WHITE hover:shadow-sm transition-colors"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center text-white text-lg"
            >🚌</span
          >
          <div>
            <p class="text-black font-semibold">GSRTC Bus Stop</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>Sola Bhagwath Vidyapith</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >1.8 km</span
              >
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-colors"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center text-white text-lg"
            >🚇</span
          >
          <div>
            <p class="text-black font-semibold">Metro Station</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>Thaltej Metro Station</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >5.8 km</span
              >
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-colors"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items_center justify-center text-white text-lg"
            >🚌</span
          >
          <div>
            <p class="text-black font-semibold">Bus Depot</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>Ahmedabad (Gita Mandir)</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >13 km</span
              >
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-colors sm:col-span-2 lg:col-span-1"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center text-white text-lg"
            >🚉</span
          >
          <div>
            <p class="text-black font-semibold">Railway Station</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>Ahmedabad (Kalupur)</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >12.5 km</span
              >
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-4 p-5 rounded-2xl border border-gray-100 bg-gray-50 hover:bg-white hover:shadow-sm transition-colors sm:col-span-2 lg:col-span-1"
        >
          <span
            class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center text-white text-lg"
            >✈️</span
          >
          <div>
            <p class="text-black font-semibold">Airport</p>
            <div class="flex items-center gap-2 text-gray-600 text-sm">
              <span>SVPI Airport</span>
              <span
                class="inline-block px-2 py-0.5 text-xs bg-green-100 text-green-700 rounded-full"
                >13 km</span
              >
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <div class="my-12 px-4">
    <div
      class="bg_white rounded-2xl shadow-lg overflow-hidden w-full max-w-6xl mx-auto border border-gray-100"
    >
      <div class="relative w-full" style="aspect-ratio: 16 / 9;">
        <iframe
          src="https://www.google.com/maps/d/embed?mid=10QGVjTs4XnCMNiFAl8VxStHAgt5BOiQ&hl=en&ehbc=2E312F"
          class="absolute inset-0 w-full h-full border-0"
          loading="lazy"
          allowfullscreen></iframe>
      </div>
    </div>
  </div>
</Layout>
