---
import Layout from "../components/Layout.astro";
import Navigation from "../components/Navigation.jsx";
// import { VENUE } from '../config.ts';
import "../styles/global.css";
---

<Layout title="Venue - OpenSource Weekend 2025">
  <Navigation client:load />

  <!-- Page Header -->
  <section class="pt-12 pb-8 px-4 bg-white">
    <div class="max-w-6xl mx-auto text-center">
      <div class="mb-4 flex justify-center">
        <img src="/icons/OSDLogo.svg" alt="Open Source Day Logo" class="w-12 h-12 md:w-16 md:h-16" />
      </div>
      <h1 class="text-4xl md:text-6xl font-bold gradient-text mb-4">The Venue</h1>
      <div class="w-32 h-1 mx-auto mt-2 rounded-full bg-gradient-to-r from-green-300 to-green-500"></div>
      <p class="text-lg text-gray-600 max-w-3xl mx-auto mt-4">Join us at a premium venue in the heart of the tech hub, designed for collaboration and innovation.</p>
    </div>
  </section>

  <!-- Venue Details -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-4xl font-bold text-black mb-6">Event Venue</h2>
          <div class="space-y-6">
            <div class="flex items-start space-x-4">
              <div
                class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1"
              >
                <svg
                  class="w-4 h-4 text-black"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-black mb-2">Location</h3>
                <p class="text-black">
                  Venue details will be shared<br />
                  with registered participants<br />
                  via email confirmation
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div
                class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1"
              >
                <svg
                  class="w-4 h-4 text-white"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                    clip-rule="evenodd"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-black mb-2">
                  Date & Time
                </h3>
                <p class="text-black">
                  February 15, 2025<br />
                  9:00 AM - 6:00 PM<br />
                  Full day event
                </p>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div
                class="w-8 h-8 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0 mt-1"
              >
                <svg
                  class="w-4 h-4 text-white"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"
                  ></path>
                  <path
                    d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1V8a1 1 0 00-1-1h-3z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-xl font-semibold text-black mb-2">
                  Accessibility
                </h3>
                <p class="text-black">
                  Wheelchair accessible venue<br />
                  Public transport connectivity<br />
                  Parking facilities available
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="light-card rounded-xl p-8">
          <h3 class="text-2xl font-bold text-black mb-6">Venue Features</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Main Auditorium (800 seats)</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">5 Workshop Rooms</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Exhibition Hall</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Networking Lounge</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">High-Speed WiFi</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Live Streaming Setup</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Food Court</span>
            </div>
            <div class="flex items-center space-x-3">
              <div class="w-2 h-2 bg-green-500 rounded-full"></div>
              <span class="text-black">Accessibility Features</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <section class="py-20 px-4 bg-gradient-to-r from-gray-900/50 to-black/50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-center text-white mb-12">
        Location & Directions
      </h2>
      <div class="bg-gray-800 rounded-xl p-8 border border-green-500/20">
        <div
          class="aspect-video bg-gray-700 rounded-lg flex items-center justify-center mb-6"
        >
          <p class="text-black-400">Interactive Map Coming Soon</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="text-center">
            <h3 class="text-xl font-semibold text-green-400 mb-2">By Car</h3>
            <p class="text-black-300">Easy access from Highway 101 and I-280</p>
          </div>
          <div class="text-center">
            <h3 class="text-xl font-semibold text-green-400 mb-2">
              Public Transit
            </h3>
            <p class="text-black-300">
              BART and Muni stations within walking distance
            </p>
          </div>
          <div class="text-center">
            <h3 class="text-xl font-semibold text-green-400 mb-2">Airport</h3>
            <p class="text-black-300">
              20 minutes from SFO, 30 minutes from Oakland
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hotels Section -->
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-4xl font-bold text-center text-white mb-12">
        Recommended Hotels
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div
          class="bg-gray-900/50 rounded-xl border border-green-500/20 backdrop-blur-sm p-6"
        >
          <h3 class="text-xl font-bold text-white mb-2">Tech Hotel Downtown</h3>
          <p class="text-green-400 mb-2">0.5 miles away</p>
          <p class="text-black-300 mb-4">
            Modern hotel with tech-friendly amenities
          </p>
          <p class="text-sm text-black-400">Special rate: $199/night</p>
        </div>
        <div
          class="bg-gray-900/50 rounded-xl border border-green-500/20 backdrop-blur-sm p-6"
        >
          <h3 class="text-xl font-bold text-white mb-2">Innovation Suites</h3>
          <p class="text-green-400 mb-2">0.8 miles away</p>
          <p class="text-black-300 mb-4">
            Luxury suites perfect for extended stays
          </p>
          <p class="text-sm text-black-400">Special rate: $249/night</p>
        </div>
        <div
          class="bg-gray-900/50 rounded-xl border border-green-500/20 backdrop-blur-sm p-6"
        >
          <h3 class="text-xl font-bold text-white mb-2">Budget Stay Plus</h3>
          <p class="text-green-400 mb-2">1.2 miles away</p>
          <p class="text-black-300 mb-4">
            Comfortable and affordable accommodation
          </p>
          <p class="text-sm text-black-400">Special rate: $129/night</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
