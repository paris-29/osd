---
import Layout from "@/layouts/Layout.astro";
import Heading from "@components/Heading.astro";
import "@/styles/global.css";

import Location from "@/assets/icons/location.svg";
import CalendarClock from "@/assets/icons/calendarClock.svg";
import LayoutList from "@/assets/icons/layoutList.svg";

import { VENUE } from "@/config";
---

<Layout title="Venue — 2025 OSD">
  <!-- Heading Section -->
  <Heading title="The Venue" />

  <!-- SOU Overview Card -->
  <section class="py-8 px-4 bg-white">
    <div class="max-w-4xl mx-auto bg-green-50 border border-green-100 rounded-2xl shadow flex flex-col md:flex-row items-center gap-6 p-8">
      <div class="flex-shrink-0 flex items-center justify-center w-20 h-20 bg-green-500 rounded-full">
        <!-- You can replace this with the SOU logo if available -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 40 40"
          class="w-12 h-12 text-white"
        >
          <rect width="40" height="40" rx="20" fill="currentColor" />
          <path
            d="M20 12l8 4-8 4-8-4 8-4zm0 6.5l6.93-3.47A1 1 0 0026 14.13l-6 3-6-3a1 1 0 00-.93 1.9L20 18.5z"
            fill="#A7F3D0"
          />
        </svg>
      </div>
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-green-700 mb-2">
          Silver Oak University (SOU)
        </h2>
        <p class="text-gray-800 text-base md:text-lg leading-relaxed">
          Silver Oak University (SOU) is a premier private university, continuing
          the legacy of the Silver Oak Group of Institutes. Guided by its motto,
          <span class="italic">“Gyanam Param Bhushanam”</span> (“Knowledge is
          the highest virtue”), SOU offers a dynamic and inspiring environment
          for tech enthusiasts. The state-of-the-art campus features a futuristic
          curriculum, advanced technology, eminent faculty, strong
          industry-academia connections, and ample career opportunities - making it
          the perfect venue for innovation and collaboration.
        </p>
      </div>
    </div>
  </section>

  <!-- Venue Section -->
  <section class="py-10 px-4 bg-white">
    <div class="max-w-5xl mx-auto bg-white rounded-2xl shadow-xl flex flex-col md:flex-row overflow-hidden border border-gray-100">
      <!-- Left: Venue Details -->
      <div class="md:w-1/2 p-8 flex flex-col justify-center bg-white">
        <h2 class="text-2xl font-bold text-green-600 mb-6">Venue Details</h2>
        <div class="flex items-start gap-4 mb-6">
          <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <Location />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-1">Location</h3>
            <p class="text-gray-700">
              Ahmedabad, Gujarat<br />
              <span class="text-sm text-gray-500"
                >Exact venue details will be shared with registered participants via
                email confirmation.</span
              >
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4 mb-6">
          <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <CalendarClock />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-1">Date & Time</h3>
            <p class="text-gray-700">
              October 05, 2025<br />
              9:00 AM - 6:00 PM<br />
              <span class="text-sm text-gray-500">Full day event</span>
            </p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center flex-shrink-0">
            <LayoutList />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-black mb-1">Accessibility</h3>
            <ul class="list-disc list-inside text-gray-700 text-base">
              <li>Wheelchair accessible venue</li>
              <li>Public transport connectivity</li>
              <li>Parking facilities available</li>
            </ul>
          </div>
        </div>
      </div>
      <!-- Divider -->
      <div class="hidden md:block w-px bg-gray-100"></div>
      <!-- Right: Venue Features -->
      <div class="md:w-1/2 p-8 bg-gray-50 flex flex-col justify-center">
        <h2 class="text-2xl font-bold text-green-600 mb-6">Venue Features</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >A</span
            >
            <span class="text-gray-800">Main Auditorium (600 seats)</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >W</span
            >
            <span class="text-gray-800">5 Workshop Rooms</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >E</span
            >
            <span class="text-gray-800">Exhibition Hall</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >N</span
            >
            <span class="text-gray-800">Networking Lounge</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >W</span
            >
            <span class="text-gray-800">High-Speed WiFi</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >L</span
            >
            <span class="text-gray-800">Live Streaming Setup</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >F</span
            >
            <span class="text-gray-800">Food Court</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white font-bold"
              >A</span
            >
            <span class="text-gray-800">Accessibility Features</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map Section -->
  <div class="my-12 flex justify-center">
    <div class="bg-white rounded-2xl shadow-lg overflow-hidden w-full max-w-3xl border border-gray-100">
      <iframe
        src="https://www.google.com/maps/d/embed?mid=10QGVjTs4XnCMNiFAl8VxStHAgt5BOiQ&hl=en&ehbc=2E312F"
        class="w-full h-[400px] md:h-[480px] border-0"
        loading="lazy"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <!-- Transport & Connectivity Section -->
  <section class="pb-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto bg-green-50 border border-green-100 rounded-2xl shadow p-8">
      <h2 class="text-2xl font-bold text-green-700 mb-6">Transport & Connectivity</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-gray-800">
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">🚌</span>
          <span><span class="font-semibold">Nearest AMTS Bus Stop:</span> Silver Oak University (100m)</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">🚍</span>
          <span><span class="font-semibold">Nearest BRTS Bus Stop:</span> Gota Cross Road (1.2 km)</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">🚌</span>
          <span><span class="font-semibold">Nearest GSRTC Bus Stop:</span> Sola Bhagwath Vidyapith (1.8 km)</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">🚇</span>
          <span><span class="font-semibold">Nearest Metro Station:</span> Thaltej Metro Station (5.8 km)</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">🚌</span>
          <span><span class="font-semibold">Nearest Bus Depot:</span> Ahmedabad Bus Depot (Gita Mandir) (13 km)</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">🚉</span>
          <span><span class="font-semibold">Nearest Railway Station:</span> Ahmedabad Railway Station (Kalupur) (12.5 km)</span>
        </li>
        <li class="flex items-center gap-3">
          <span class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center text-white font-bold text-lg">✈️</span>
          <span><span class="font-semibold">Nearest Airport:</span> Sardar Vallabhbhai Patel International Airport (13 km)</span>
        </li>
      </ul>
    </div>
  </section>
</Layout>
