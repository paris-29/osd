---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
import { VENUE } from "@/config/config";
import LocationIcon from "@/assets/icons/location.svg";
import PageHero from "@/components/PageHero.jsx";
---

<Layout title="Venue — Open Source Day 2026" activePath="/venue">
  <!-- Hero -->
  <PageHero client:load
    badge="VENUE ANNOUNCEMENT COMING SOON"
    title="OSD 2026"
    titleGradient="VENUE"
    subtitle="We'll be in Ahmedabad, Gujarat for another epic edition. The exact venue will be announced soon."
    primaryCta={{ text: "Get Notified", href: "https://chat.whatsapp.com/Fi50G9prGcH4b7891LrPir", external: true }}
    secondaryCta={{ text: "View 2025 Venue", href: "/2025/venue" }}
  />

  <!-- Location Info -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center mb-16">
        <div>
          <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-6">Event <span class="gradient-text">Location</span></h2>
          <div class="space-y-3">
            {[
              { label: "City", value: "Ahmedabad, Gujarat, India" },
              { label: "Venue", value: VENUE.name },
              { label: "Date", value: "TBA" },
              { label: "Format", value: "Full day event (8 AM – 6 PM)" },
              { label: "Capacity", value: VENUE.capacity },
            ].map(({ label, value }) => (
              <div class="flex items-start gap-3 border border-gray-100 bg-white hover:border-green-100 p-4 rounded-2xl transition-all">
                <div class="w-5 h-5 mt-0.5 text-green-600 shrink-0"><LocationIcon /></div>
                <div>
                  <div class="font-bold text-gray-900 text-sm">{label}</div>
                  <div class="text-gray-500 text-sm">{value}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <!-- Map placeholder -->
        <div class="bg-gray-50 border border-gray-100 rounded-2xl h-72 flex items-center justify-center">
          <div class="text-center">
            <div class="w-12 h-12 mx-auto mb-3 text-green-400"><LocationIcon /></div>
            <p class="text-gray-500 font-semibold">Map coming soon</p>
            <p class="text-gray-400 text-sm mt-1">Venue TBA · Ahmedabad, Gujarat</p>
          </div>
        </div>
      </div>

      <!-- Facilities -->
      <div>
        <div class="flex items-center gap-3 mb-8">
          <div class="h-px flex-1 bg-gray-200"></div>
          <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Facilities</span>
          <div class="h-px flex-1 bg-gray-200"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
          {VENUE.facilities.map((f) => (
            <div class="flex items-center gap-3 border border-gray-100 bg-white p-4 rounded-2xl hover:border-green-100 transition-all">
              <div class="w-5 h-5 text-green-500 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
              </div>
              <span class="text-gray-700 text-sm">{f}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Getting There -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 mb-3">Getting <span class="gradient-text">There</span></h2>
        <p class="text-gray-500">Ahmedabad is well connected by air, rail, and road</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { label: "By Air", desc: "Sardar Vallabhbhai Patel International Airport (AMD) serves Ahmedabad.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />` },
          { label: "By Train", desc: "Ahmedabad Junction is well-connected to major cities across India.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />` },
          { label: "By Road", desc: "Excellent connectivity from across Gujarat and neighboring states. Ample parking.", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V6.375a1.125 1.125 0 0 1 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v11.25m-12 0v1.5a1.5 1.5 0 0 0 3 0v-1.5m9 0v1.5a1.5 1.5 0 0 0 3 0v-1.5m0-11.25h2.625c.621 0 1.125.504 1.125 1.125V15m-18.75 0h18.75" />` },
        ].map(({ label, desc, icon }) => (
          <div class="border border-gray-100 bg-white hover:border-green-200 hover:shadow-md p-7 rounded-2xl transition-all duration-300">
            <div class="w-10 h-10 mb-4 text-green-600">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" set:html={icon}></svg>
            </div>
            <h3 class="font-bold text-gray-900 mb-2">{label}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 2025 Reference -->
  <section class="py-16 px-4 bg-white text-center">
    <h3 class="text-2xl font-black text-gray-900 mb-3">OSD 2025 was at <span class="gradient-text">Silver Oak University</span></h3>
    <p class="text-gray-500 mb-6 max-w-xl mx-auto">Check out the 2025 venue details and photos from the event.</p>
    <a href="/2025/venue" class="inline-flex items-center gap-2 font-bold text-white bg-gray-900 hover:bg-gray-800 px-8 py-3 rounded-full transition-all hover:scale-105">
      View 2025 Venue
    </a>
  </section>

  <!-- Bottom CTA -->
  <section class="py-16 px-4 bg-gray-50 text-center">
    <h3 class="text-xl font-bold text-gray-900 mb-2">Want to be a <span class="gradient-text">venue partner?</span></h3>
    <p class="text-gray-500 mb-2">Reach out to us at</p>
    <a href="mailto:opensourceweekend@gmail.com" class="text-green-600 hover:underline font-semibold">opensourceweekend@gmail.com</a>
  </section>
</Layout>
