---
import Layout from "@/layouts/Layout.astro";
import "@/styles/2025/global.css";
import BadgeCreator from "@/components/badge/BadgeCreator";
---

<Layout title="Creator Badge — Open Source Day 2026" activePath="/badges">
  <div class="min-h-screen bg-[#f8fafc]">
    <BadgeCreator client:load />
  </div>
</Layout>

<style is:global>
  /* Ensure smooth transitions for the badge creator */
  .badge-render-container {
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Custom scrollbar for a premium look */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #f8fafc;
  }
  ::-webkit-scrollbar-thumb {
    background: #e2e8f0;
    border-radius: 10px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #cbd5e1;
  }
</style>
