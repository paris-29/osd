---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

export interface Props {
  name: string;
  position: string;
  company: string;
  presentationTitle: string;
  event?: string;
  presentationLink?: string;
  width: number;
  link?: string;
  image: ImageMetadata;
  class?: string;
  tags?: Array<string>;
}

const {
  name,
  position,
  company,
  presentationTitle,
  event,
  presentationLink,
  image,
  link = "",
  width = 400,
  tags,
  class: className,
} = Astro.props;
---

<div
  class:list={[
    "w-full bg-green-100 shadow-gray-300 rounded-2xl shadow-md overflow-hidden border-2 pb-4",
    className,
  ]}
>
  <a href={link} target="_blank" rel="noopener noreferrer">
    <div
      class="relative w-full aspect-[3/4] min-h-[400px] pb-[133%] overflow-hidden"
    >
      <Image
        src={image}
        alt={name}
        width={width}
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
    </div>

    <div>
      <h3 class="text-xl px-4 pt-3 pb-1 border-t-2 font-bold text-gray-900">
        {name}
      </h3>
      {
        position && company && (
          <p class="text-sm px-4 text-gray-900">
            <span>{position}</span>,<span class="font-bold"> {company}</span>
          </p>
        )
      }

      {
        tags && (
          <p class="text-sm px-4 text-gray-900">
            {tags.map((tag) => (
              <span class="text-sm bg-green-200 rounded-full drop-shadow-xl shadow-gray-800 border-2 mt-1 mx-0.5 py-0.3 inline-block px-2">
                {tag}
              </span>
            ))}
          </p>
        )
      }

      {
        (event || presentationTitle) && (
          <dl class="pt-4 px-4 ">
            {event && (
              <dt class="text-[0.7rem] font-bold shadow-gray-800 drop-shadow-xl rounded-t-xl bg-green-200 px-2 py-1 border-x-2 border-t-2 inline-block text-gray-800">
                {event.toUpperCase()}
              </dt>
            )}
            <br />
            {presentationTitle && (
              <dd class="text-[0.95rem] drop-shadow-xl shadow-gray-600 font-medium text-gray-800 inline-block min-w-full min-h-full rounded-b-xl rounded-tr-xl border-2  px-2 py-1 bg-green-300">
                {presentationTitle}
              </dd>
            )}
          </dl>
        )
      }

      {
        presentationLink && (
          <span class="pt-4 px-2">
            <a
              href={presentationLink}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1 px-3 py-1 whitespace-nowrap rounded-full text-xs font-semibold border-2 text-black border-black bg-orange-300"
            >
              <span class="uppercase">Presentation</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="size-3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"
                />
              </svg>
            </a>
          </span>
        )
      }
    </div>
  </a>
</div>
