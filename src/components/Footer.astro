---
import { FOOTER, BRANDING, SITE, SOCIAL_LINKS, CONTACTS } from "../config/config.ts";
---

<footer class="bg-gray-50 border-t border-green-500/20 py-16 px-4">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
    {/* Logo, description, socials */}
    <section class="md:col-span-2">
      <div class="flex items-center mb-4">
        <img
          src={BRANDING.logos.main.src}
          alt="OSW Logo"
          class="w-12 h-12 mr-3"
        />
        <h3 class="text-3xl font-bold gradient-text">{SITE.shortTitle}</h3>
      </div>
      <p class="text-black max-w-md mb-6">{FOOTER.description}</p>
      <nav class="flex gap-4">
        {
          SOCIAL_LINKS.map((media) => (
            <a
              href={media.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={media.name}
              class="w-10 h-10 border-2 border-gray-300 bg-white rounded-lg flex items-center justify-center hover:bg-green-500 hover:text-white hover:border-green-500 transition"
            >
              <img
                src={media.icon.src}
                alt={media.description}
                class="w-6 h-6"
              />
            </a>
          ))
        }
      </nav>
    </section>

    {/* Contacts */}
    <section class="text-black space-y-3">
      <h4 class="font-semibold text-lg">Contact Us</h4>
      {
        CONTACTS.map((item) => (
          <div class="flex items-center gap-3">
            <a href={item.href} class="hover:text-green-600 transition-colors">
              {item.content}
            </a>
          </div>
        ))
      }
    </section>
  </div>

  <div class="mt-4 pt-4 border-t text-center border-gray-300 text-sm text-black">
    <p>
      Made with ❤️ by <a href="https://github.com/oscfcommunity" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:underline">Open Source Weekend community</a>!<br />
      &copy; {new Date().getFullYear()} Open Source Weekend. All rights reserved.
    </p>
  </div>
</footer>
